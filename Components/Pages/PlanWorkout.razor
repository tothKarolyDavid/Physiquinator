@page "/plan"
@page "/plan/{PlanId:guid}"
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="plan-page-with-footer @(IsNew ? "has-bottom-nav" : "")">
    <PageHeader Title="@(IsNew ? "New plan" : "Edit plan")" OnBack="GoHome" />

    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudStack Spacing="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="PlanName"
                                  Label="Plan name"
                                  Placeholder="e.g. Push day"
                                  Required="true"
                                  RequiredError="Plan name is required"
                                  Immediate="true" />
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="DefaultSetCount" Label="Default sets" Min="1" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="RestIntervalSeconds" Label="Default rest (s)" Min="0" />
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            <MudText Typo="Typo.h6">Exercises</MudText>

            @if (!Exercises.Any())
            {
                <EmptyState Message="No exercises yet. Add one below."
                            Icon="@Icons.Material.Outlined.List" />
            }
            else
            {
                <div id="exercise-sortable-list" class="exercise-sortable-list">
                    @for (var i = 0; i < Exercises.Count; i++)
                    {
                        var idx = i;
                        <MudPaper @key="Exercises[idx].Id" Class="pa-2 exercise-sortable-item" Elevation="1">
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.DragIndicator"
                                                   Class="exercise-drag-handle"
                                                   aria-label="Drag to reorder" />
                                    <MudTextField @bind-Value="Exercises[idx].Name"
                                                  Label="Exercise"
                                                  Placeholder="Exercise name"
                                                  Class="flex-grow-1"
                                                  Required="true" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   aria-label="Remove exercise"
                                                   OnClick="@(() => RemoveExercise(idx))" />
                                </MudStack>
                                <MudGrid Spacing="2">
                                    <MudItem xs="6" sm="3">
                                        <MudNumericField @bind-Value="Exercises[idx].SetCount" Label="Sets" Min="1" />
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudNumericField @bind-Value="Exercises[idx].RestIntervalSeconds" Label="Rest (s)" Min="0" />
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudNumericField @bind-Value="Exercises[idx].DefaultReps" Label="Def reps" Min="0" HideSpinButtons="true" />
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudNumericField @bind-Value="Exercises[idx].DefaultWeightKg" Label="Def kg" Min="0" HideSpinButtons="true" />
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudPaper>
                    }
                </div>
            }

            <MudPaper Class="pa-2" Elevation="1">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudTextField @bind-Value="NewExerciseName"
                                  Placeholder="Add new exercise…"
                                  Class="flex-grow-1"
                                  OnKeyDown="AddExerciseKeydown" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddExercise">
                        Add
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    </MudForm>
</div>

<MudPaper Elevation="8" Class="plan-sticky-footer">
    <div class="plan-sticky-footer__actions">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@SaveDisabled">
            Save
        </MudButton>
        <MudButton Variant="Variant.Text" OnClick="GoHome">Cancel</MudButton>
        @if (!IsNew)
        {
            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                           Color="Color.Secondary"
                           aria-label="Start workout"
                           Href="@($"/workout/{PlanId}")" />
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AriaLabel="More actions" Dense="true">
                <MudMenuItem Icon="@Icons.Material.Filled.Upload" OnClick="ExportCurrentPlan">
                    Export plan
                </MudMenuItem>
            </MudMenu>
        }
    </div>
</MudPaper>

@code {
    [Parameter]
    public Guid? PlanId { get; set; }

    private MudForm? _form;
    private bool _formValid;
    private string PlanName { get; set; } = "Workout";
    private int RestIntervalSeconds { get; set; } = 60;
    private int DefaultSetCount { get; set; } = 4;
    private List<ExercisePlan> Exercises { get; set; } = new();
    private string NewExerciseName { get; set; } = "";
    private bool IsNew => PlanId == null;
    private DotNetObjectReference<object>? _dotNetRef;
    private int _lastSortableCount = -1;

    private bool CanSave => !string.IsNullOrWhiteSpace(PlanName) && Exercises.Any() && Exercises.All(e => !string.IsNullOrWhiteSpace(e.Name));
    private bool SaveDisabled => !CanSave;

    protected override async Task OnInitializedAsync()
    {
        if (PlanId.HasValue)
        {
            var plan = await PlanService.GetPlanAsync(PlanId.Value);
            if (plan != null)
            {
                PlanName = plan.Name;
                RestIntervalSeconds = plan.RestIntervalSeconds;
                DefaultSetCount = plan.DefaultSetCount;
                Exercises = plan.Exercises.OrderBy(e => e.Order).Select(e => new ExercisePlan
                {
                    Id = e.Id,
                    Name = e.Name,
                    SetCount = e.SetCount,
                    Order = e.Order,
                    RestIntervalSeconds = e.RestIntervalSeconds,
                    DefaultReps = e.DefaultReps,
                    DefaultWeightKg = e.DefaultWeightKg
                }).ToList();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Exercises.Count == 0)
        {
            if (_lastSortableCount != 0)
            {
                await DestroySortableAsync();
                _lastSortableCount = 0;
            }
            return;
        }

        if (_lastSortableCount == Exercises.Count && !firstRender)
            return;

        await InitSortableAsync();
        _lastSortableCount = Exercises.Count;
    }

    private async ValueTask DestroySortableAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("planReorder.destroy");
        }
        catch (JSException)
        {
            // planReorder loads from theme.js; ignore if scripts not ready yet
        }
    }

    private async ValueTask InitSortableAsync()
    {
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create<object>(this);
            await DestroySortableAsync();
            await JS.InvokeVoidAsync("planReorder.init", "exercise-sortable-list", _dotNetRef);
        }
        catch (JSException)
        {
            // Sortable or planReorder not loaded yet
        }
    }

    [JSInvokable]
    public void OnExerciseReordered(int oldIndex, int newIndex)
    {
        if (oldIndex < 0 || newIndex < 0 || oldIndex >= Exercises.Count || newIndex >= Exercises.Count)
            return;

        if (oldIndex == newIndex)
            return;

        var item = Exercises[oldIndex];
        Exercises.RemoveAt(oldIndex);
        Exercises.Insert(newIndex, item);
        RenumberExercises();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await DestroySortableAsync();
        }
        catch (JSDisconnectedException)
        {
            // WebView disposed
        }

        _dotNetRef?.Dispose();
    }

    private void GoHome() => Navigation.NavigateTo("/");

    private void AddExercise()
    {
        if (string.IsNullOrWhiteSpace(NewExerciseName)) return;
        Exercises.Add(new ExercisePlan
        {
            Name = NewExerciseName.Trim(),
            SetCount = DefaultSetCount,
            Order = Exercises.Count,
            RestIntervalSeconds = RestIntervalSeconds
        });
        NewExerciseName = "";
        _lastSortableCount = -1;
    }

    private void AddExerciseKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddExercise();
    }

    private void RemoveExercise(int index)
    {
        if (index >= 0 && index < Exercises.Count)
        {
            Exercises.RemoveAt(index);
            RenumberExercises();
            _lastSortableCount = -1;
        }
    }

    private void RenumberExercises()
    {
        for (var i = 0; i < Exercises.Count; i++)
            Exercises[i].Order = i;
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var plan = new WorkoutPlan
        {
            Id = PlanId ?? Guid.NewGuid(),
            Name = PlanName.Trim(),
            RestIntervalSeconds = RestIntervalSeconds,
            DefaultSetCount = DefaultSetCount,
            Exercises = Exercises.Select((e, i) => new ExercisePlan
            {
                Id = e.Id,
                Name = e.Name.Trim(),
                SetCount = e.SetCount,
                Order = i,
                RestIntervalSeconds = e.RestIntervalSeconds,
                DefaultReps = e.DefaultReps,
                DefaultWeightKg = e.DefaultWeightKg
            }).ToList()
        };
        await PlanService.SavePlanAsync(plan);
        Snackbar.Add("Plan saved.", Severity.Success);
        Navigation.NavigateTo("/");
    }

    private async Task ExportCurrentPlan()
    {
        if (!PlanId.HasValue) return;
        try
        {
            var json = await PlanService.ExportPlanToJsonAsync(PlanId.Value);
            var safeFileName = string.Join("_", PlanName.Split(Path.GetInvalidFileNameChars()));
            var fileName = $"{safeFileName}_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            await File.WriteAllTextAsync(filePath, json);
            await Share.RequestAsync(new ShareFileRequest
            {
                Title = "Export Workout Plan",
                File = new ShareFile(filePath)
            });
            Snackbar.Add("Plan exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }
}
