@page "/plan"
@page "/plan/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="plan-page">
    <PageHeader Title="@(IsNew ? "New plan" : "Edit plan")" OnBack="GoHome" />

    @if (!IsNew && !string.IsNullOrWhiteSpace(PlanName))
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary plan-page__subtitle mb-3">@PlanName</MudText>
    }

    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudStack Spacing="3">
            <section class="plan-section">
                <MudText Typo="Typo.overline" Class="plan-section__label">Plan details</MudText>
                <MudPaper Class="plan-details-card plan-section__card pa-3" Elevation="0">
                    <MudStack Spacing="2">
                        <MudTextField @bind-Value="PlanName"
                                      Variant="Variant.Filled"
                                      Label="Plan name"
                                      Placeholder="e.g. Push day"
                                      Required="true"
                                      RequiredError="Plan name is required"
                                      Immediate="true" />
                        <MudGrid Spacing="2" Class="plan-details-card__grid">
                            <MudItem xs="6">
                                <SetMetricStepper Label="Default sets"
                                                  @bind-Value="DefaultSetCountValue"
                                                  Step="1"
                                                  Min="1"
                                                  IsInteger="true"
                                                  Format="0"
                                                  InputMode="numeric" />
                            </MudItem>
                            <MudItem xs="6">
                                <SetMetricStepper Label="Default rest (s)"
                                                  @bind-Value="RestIntervalSecondsValue"
                                                  Step="5"
                                                  Min="0"
                                                  IsInteger="true"
                                                  Format="0"
                                                  InputMode="numeric" />
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                </MudPaper>
            </section>

            <section class="plan-section">
                <MudText Typo="Typo.overline" Class="plan-section__label">Exercises</MudText>

                @if (!Exercises.Any())
                {
                    <EmptyState Message="Add your first exercise to build this plan."
                                Icon="@Icons.Material.Outlined.FitnessCenter">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="FocusAddExercise">
                            Add exercise
                        </MudButton>
                    </EmptyState>
                }
                else
                {
                    <PlanExerciseList Exercises="Exercises"
                                      SortableVersion="_sortableVersion"
                                      OnReordered="HandleReordered"
                                      OnEdit="EditExerciseAsync"
                                      OnDelete="ConfirmRemoveExerciseAsync" />
                }

                <div class="plan-add-exercise">
                    <MudTextField @bind-Value="NewExerciseName"
                                  @ref="_newExerciseField"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="Add exercise…"
                                  Class="plan-add-exercise__input"
                                  OnKeyDown="AddExerciseKeydown" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="plan-add-exercise__btn"
                               OnClick="AddExerciseAsync"
                               Disabled="@string.IsNullOrWhiteSpace(NewExerciseName)">
                        Add
                    </MudButton>
                </div>
            </section>
        </MudStack>
    </MudForm>

    <PlanEditorFooter IsNew="IsNew"
                  SaveDisabled="@SaveDisabled"
                  OnSave="Save"
                  OnCancel="GoHome"
                  OnExport="ExportCurrentPlan" />
</div>

@code {
    [Parameter]
    public Guid? PlanId { get; set; }

    private MudForm? _form;
    private MudTextField<string>? _newExerciseField;
    private bool _formValid;
    private string PlanName { get; set; } = "Workout";
    private int RestIntervalSeconds { get; set; } = 60;
    private int DefaultSetCount { get; set; } = 4;
    private List<ExercisePlan> Exercises { get; set; } = new();
    private string NewExerciseName { get; set; } = "";
    private int _sortableVersion;
    private bool IsNew => PlanId == null;

    private bool CanSave => !string.IsNullOrWhiteSpace(PlanName)
        && Exercises.Any()
        && Exercises.All(e => !string.IsNullOrWhiteSpace(e.Name));

    private bool SaveDisabled => !CanSave;

    private double? DefaultSetCountValue
    {
        get => DefaultSetCount;
        set => DefaultSetCount = Math.Max(1, (int)Math.Round(value ?? 1));
    }

    private double? RestIntervalSecondsValue
    {
        get => RestIntervalSeconds;
        set => RestIntervalSeconds = Math.Max(0, (int)Math.Round(value ?? 0));
    }

    protected override async Task OnInitializedAsync()
    {
        if (PlanId.HasValue)
        {
            var plan = await PlanService.GetPlanAsync(PlanId.Value);
            if (plan != null)
            {
                PlanName = plan.Name;
                RestIntervalSeconds = plan.RestIntervalSeconds;
                DefaultSetCount = plan.DefaultSetCount;
                Exercises = plan.Exercises.OrderBy(e => e.Order).Select(e => new ExercisePlan
                {
                    Id = e.Id,
                    Name = e.Name,
                    SetCount = e.SetCount,
                    Order = e.Order,
                    RestIntervalSeconds = e.RestIntervalSeconds,
                    DefaultReps = e.DefaultReps,
                    DefaultWeightKg = e.DefaultWeightKg
                }).ToList();
            }
        }
    }

    private void BumpSortable() => _sortableVersion++;

    private void HandleReordered((int OldIndex, int NewIndex) args)
    {
        var (oldIndex, newIndex) = args;
        if (oldIndex < 0 || newIndex < 0 || oldIndex >= Exercises.Count || newIndex >= Exercises.Count)
            return;

        var item = Exercises[oldIndex];
        Exercises.RemoveAt(oldIndex);
        Exercises.Insert(newIndex, item);
        RenumberExercises();
        BumpSortable();
    }

    private void GoHome() => Navigation.NavigateTo("/");

    private async Task FocusAddExercise()
    {
        if (_newExerciseField != null)
            await _newExerciseField.FocusAsync();
    }

    private async Task AddExerciseAsync()
    {
        if (string.IsNullOrWhiteSpace(NewExerciseName))
            return;

        var exercise = new ExercisePlan
        {
            Name = NewExerciseName.Trim(),
            SetCount = DefaultSetCount,
            Order = Exercises.Count,
            RestIntervalSeconds = RestIntervalSeconds
        };
        NewExerciseName = "";
        BumpSortable();
        await EditExerciseAsync(exercise, isNew: true, insertAtEnd: true);
    }

    private void AddExerciseKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            _ = AddExerciseAsync();
    }

    private async Task EditExerciseAsync(int index)
    {
        if (index < 0 || index >= Exercises.Count)
            return;

        await EditExerciseAsync(Exercises[index], isNew: false);
    }

    private async Task EditExerciseAsync(ExercisePlan exercise, bool isNew = false, bool insertAtEnd = false)
    {
        var parameters = new DialogParameters<PlanExerciseSheet>
        {
            { x => x.Exercise, CloneExercise(exercise) },
            { x => x.IsNew, isNew }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            Position = DialogPosition.BottomCenter,
        };

        var dialog = await DialogService.ShowAsync<PlanExerciseSheet>(
            isNew ? "Add exercise" : "Edit exercise",
            parameters,
            options);
        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is ExercisePlan updated)
        {
            if (isNew && insertAtEnd)
                Exercises.Add(updated);
            else
            {
                var idx = Exercises.FindIndex(e => e.Id == exercise.Id);
                if (idx >= 0)
                    Exercises[idx] = updated;
            }

            RenumberExercises();
            BumpSortable();
        }
        else if (isNew && insertAtEnd)
        {
            BumpSortable();
        }
    }

    private static ExercisePlan CloneExercise(ExercisePlan source) => new()
    {
        Id = source.Id,
        Name = source.Name,
        SetCount = source.SetCount,
        Order = source.Order,
        RestIntervalSeconds = source.RestIntervalSeconds,
        DefaultReps = source.DefaultReps,
        DefaultWeightKg = source.DefaultWeightKg
    };

    private async Task ConfirmRemoveExerciseAsync(int index)
    {
        if (index < 0 || index >= Exercises.Count)
            return;

        var name = Exercises[index].Name;
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Remove exercise",
            $"Remove '{name}' from this plan?",
            confirmText: "Remove",
            confirmColor: Color.Error);

        if (!confirmed)
            return;

        Exercises.RemoveAt(index);
        RenumberExercises();
        BumpSortable();
    }

    private void RenumberExercises()
    {
        for (var i = 0; i < Exercises.Count; i++)
            Exercises[i].Order = i;
    }

    private async Task Save()
    {
        if (!CanSave)
            return;

        var plan = new WorkoutPlan
        {
            Id = PlanId ?? Guid.NewGuid(),
            Name = PlanName.Trim(),
            RestIntervalSeconds = RestIntervalSeconds,
            DefaultSetCount = DefaultSetCount,
            Exercises = Exercises.Select((e, i) => new ExercisePlan
            {
                Id = e.Id,
                Name = e.Name.Trim(),
                SetCount = e.SetCount,
                Order = i,
                RestIntervalSeconds = e.RestIntervalSeconds,
                DefaultReps = e.DefaultReps,
                DefaultWeightKg = e.DefaultWeightKg
            }).ToList()
        };
        await PlanService.SavePlanAsync(plan);
        Snackbar.Add("Plan saved.", Severity.Success);
        Navigation.NavigateTo("/");
    }

    private async Task ExportCurrentPlan()
    {
        if (!PlanId.HasValue)
            return;

        try
        {
            var json = await PlanService.ExportPlanToJsonAsync(PlanId.Value);
            var safeFileName = string.Join("_", PlanName.Split(Path.GetInvalidFileNameChars()));
            var fileName = $"{safeFileName}_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            await File.WriteAllTextAsync(filePath, json);
            await Share.RequestAsync(new ShareFileRequest
            {
                Title = "Export Workout Plan",
                File = new ShareFile(filePath)
            });
            Snackbar.Add("Plan exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }
}
