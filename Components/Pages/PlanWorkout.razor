@page "/plan"
@page "/plan/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation

<div class="mb-2 mt-3">
    <a href="/" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<h1 class="h4 mb-3"><i class="bi bi-clipboard2-check-fill me-2"></i>@(IsNew ? "New Plan" : "Edit Plan")</h1>

<div class="plan-form">
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-6">
                    <label for="plan-name" class="form-label mb-1"><i class="bi bi-tag-fill me-1"></i>Plan Name</label>
                    <input id="plan-name" type="text" class="form-control" @bind="PlanName" placeholder="e.g. Push Day" />
                </div>
                <div class="col-6 col-md-3">
                    <label for="default-set-count" class="form-label mb-1"><i class="bi bi-repeat me-1"></i>Default Sets</label>
                    <input id="default-set-count" type="number" class="form-control" @bind="DefaultSetCount" min="1" />
                </div>
                <div class="col-6 col-md-3">
                    <label for="rest-interval" class="form-label mb-1"><i class="bi bi-clock-fill me-1"></i>Default Rest (s)</label>
                    <input id="rest-interval" type="number" class="form-control" @bind="RestIntervalSeconds" min="0" />
                </div>
            </div>
        </div>
    </div>

    <h2 class="h6 mt-3 mb-2"><i class="bi bi-list-task me-1"></i>Exercises</h2>

    <div class="exercise-list">
        @if (!Exercises.Any())
        {
            <div class="text-center py-3">
                <i class="bi bi-inbox" style="font-size: 2rem; color: #667eea; opacity: 0.3;"></i>
                <p class="text-muted mt-2 mb-0">No exercises yet. Add one below.</p>
            </div>
        }
        @for (var i = 0; i < Exercises.Count; i++)
        {
            var idx = i;
            <div class="card mb-2">
                <div class="card-body p-2">
                    <!-- First row: Up arrow + Exercise name -->
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <button type="button" class="btn btn-sm btn-link text-muted p-0" 
                                @onclick="() => MoveExerciseUp(idx)" 
                                disabled="@(idx == 0)"
                                title="Move up"
                                style="font-size: 1.2rem; line-height: 1;">
                            <i class="bi bi-chevron-up"></i>
                        </button>
                        <input type="text" class="form-control form-control-lg flex-grow-1" @bind="Exercises[idx].Name" placeholder="Exercise name" />
                    </div>
                    <!-- Second row: Down arrow + Sets, Rest time, Delete -->
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-sm btn-link text-muted p-0" 
                                @onclick="() => MoveExerciseDown(idx)" 
                                disabled="@(idx == Exercises.Count - 1)"
                                title="Move down"
                                style="font-size: 1.2rem; line-height: 1; margin-left: 1px;">
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <div class="d-flex align-items-center gap-1 flex-shrink-0">
                            <i class="bi bi-repeat text-muted"></i>
                            <input type="number" class="form-control" style="width: 60px;" @bind="Exercises[idx].SetCount" min="1" title="Sets" />
                        </div>
                        <div class="d-flex align-items-center gap-1 flex-shrink-0">
                            <i class="bi bi-hourglass-split text-muted"></i>
                            <input type="number" class="form-control" style="width: 70px;" @bind="Exercises[idx].RestIntervalSeconds" min="0" title="Rest (seconds)" />
                            <span class="text-muted">s</span>
                        </div>
                        <button type="button" class="btn btn-outline-danger btn-sm ms-auto" @onclick="() => RemoveExercise(idx)">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card mb-2">
        <div class="card-body p-2">
            <div class="d-flex gap-2 align-items-center">
                <input type="text" class="form-control flex-grow-1" @bind="NewExerciseName" placeholder="Add new exercise..." @onkeydown="AddExerciseKeydown" />
                <button type="button" class="btn btn-outline-primary" @onclick="AddExercise">
                    <i class="bi bi-plus-circle-fill"></i> Add
                </button>
            </div>
        </div>
    </div>

    <div class="mt-2 d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="Save" disabled="@(!CanSave)">
            <i class="bi bi-save-fill me-1"></i>Save
        </button>
        <a href="/" class="btn btn-secondary">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
        @if (!IsNew)
        {
            <a href="/workout/@PlanId" class="btn btn-success">
                <i class="bi bi-play-fill me-1"></i>Start
            </a>
            <button class="btn btn-outline-info" @onclick="ExportCurrentPlan">
                <i class="bi bi-download me-1"></i>Export
            </button>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid? PlanId { get; set; }

    private string PlanName { get; set; } = "Workout";
    private int RestIntervalSeconds { get; set; } = 60;
    private int DefaultSetCount { get; set; } = 4;
    private List<ExercisePlan> Exercises { get; set; } = new();
    private string NewExerciseName { get; set; } = "";
    private bool IsNew => PlanId == null;

    private bool CanSave => !string.IsNullOrWhiteSpace(PlanName) && Exercises.Any() && Exercises.All(e => !string.IsNullOrWhiteSpace(e.Name));

    protected override async Task OnInitializedAsync()
    {
        if (PlanId.HasValue)
        {
            var plan = await PlanService.GetPlanAsync(PlanId.Value);
            if (plan != null)
            {
                PlanName = plan.Name;
                RestIntervalSeconds = plan.RestIntervalSeconds;
                DefaultSetCount = plan.DefaultSetCount;
                Exercises = plan.Exercises.OrderBy(e => e.Order).Select(e => new ExercisePlan 
                { 
                    Id = e.Id, 
                    Name = e.Name, 
                    SetCount = e.SetCount, 
                    Order = e.Order,
                    RestIntervalSeconds = e.RestIntervalSeconds
                }).ToList();
            }
        }
    }

    private void AddExercise()
    {
        if (string.IsNullOrWhiteSpace(NewExerciseName)) return;
        Exercises.Add(new ExercisePlan 
        { 
            Name = NewExerciseName.Trim(), 
            SetCount = DefaultSetCount, 
            Order = Exercises.Count,
            RestIntervalSeconds = RestIntervalSeconds
        });
        NewExerciseName = "";
    }

    private void AddExerciseKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddExercise();
        }
    }

    private void RemoveExercise(int index)
    {
        if (index >= 0 && index < Exercises.Count)
        {
            Exercises.RemoveAt(index);
            for (var i = 0; i < Exercises.Count; i++)
                Exercises[i].Order = i;
        }
    }

    private void MoveExerciseUp(int index)
    {
        if (index > 0)
        {
            var temp = Exercises[index];
            Exercises[index] = Exercises[index - 1];
            Exercises[index - 1] = temp;

            // Update Order property
            for (var i = 0; i < Exercises.Count; i++)
                Exercises[i].Order = i;
        }
    }

    private void MoveExerciseDown(int index)
    {
        if (index < Exercises.Count - 1)
        {
            var temp = Exercises[index];
            Exercises[index] = Exercises[index + 1];
            Exercises[index + 1] = temp;

            // Update Order property
            for (var i = 0; i < Exercises.Count; i++)
                Exercises[i].Order = i;
        }
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var plan = new WorkoutPlan
        {
            Id = PlanId ?? Guid.NewGuid(),
            Name = PlanName.Trim(),
            RestIntervalSeconds = RestIntervalSeconds,
            DefaultSetCount = DefaultSetCount,
            Exercises = Exercises.Select((e, i) => new ExercisePlan 
            { 
                Id = e.Id, 
                Name = e.Name.Trim(), 
                SetCount = e.SetCount, 
                Order = i,
                RestIntervalSeconds = e.RestIntervalSeconds
            }).ToList()
        };
        await PlanService.SavePlanAsync(plan);
        Navigation.NavigateTo("/");
    }

    private async Task ExportCurrentPlan()
    {
        if (!PlanId.HasValue) return;

        try
        {
            var json = await PlanService.ExportPlanToJsonAsync(PlanId.Value);
            var safeFileName = string.Join("_", PlanName.Split(Path.GetInvalidFileNameChars()));
            var fileName = $"{safeFileName}_{DateTime.Now:yyyyMMdd_HHmmss}.json";

            var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            await File.WriteAllTextAsync(filePath, json);

            await Share.RequestAsync(new ShareFileRequest
            {
                Title = "Export Workout Plan",
                File = new ShareFile(filePath)
            });

            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", "Plan exported successfully!", "OK");
        }
        catch (Exception ex)
        {
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"Export failed: {ex.Message}", "OK");
        }
    }
}
