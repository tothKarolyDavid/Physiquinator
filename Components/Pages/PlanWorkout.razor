@page "/plan"
@page "/plan/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation

<div class="mb-4">
    <a href="/" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-2"></i>Back to Home
    </a>
</div>

<h1><i class="bi bi-clipboard2-check-fill me-2"></i>@(IsNew ? "New Workout Plan" : "Edit Workout Plan")</h1>

<div class="plan-form mt-4">
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title"><i class="bi bi-gear-fill me-2"></i>Plan Settings</h5>
            <div class="mb-3">
                <label for="plan-name" class="form-label"><i class="bi bi-tag-fill me-2"></i>Plan Name</label>
                <input id="plan-name" type="text" class="form-control" @bind="PlanName" placeholder="e.g. Push Day, Leg Day" />
            </div>
            <div class="mb-3">
                <label for="default-set-count" class="form-label"><i class="bi bi-repeat me-2"></i>Default Sets per Exercise</label>
                <input id="default-set-count" type="number" class="form-control" @bind="DefaultSetCount" min="1" />
                <small class="form-text">This will be used as the default for new exercises. Each exercise can have its own set count.</small>
            </div>
            <div class="mb-0">
                <label for="rest-interval" class="form-label"><i class="bi bi-clock-fill me-2"></i>Default Rest Between Sets</label>
                <div class="input-group">
                    <input id="rest-interval" type="number" class="form-control" @bind="RestIntervalSeconds" min="0" />
                    <span class="input-group-text">seconds</span>
                </div>
                <small class="form-text">This will be used as the default for new exercises. Each exercise can have its own rest interval.</small>
            </div>
        </div>
    </div>

    <h2 class="h5 mt-4 mb-3"><i class="bi bi-list-task me-2"></i>Exercises</h2>

    <div class="exercise-list">
        @if (!Exercises.Any())
        {
            <div class="text-center py-4">
                <i class="bi bi-inbox" style="font-size: 3rem; color: #667eea; opacity: 0.3;"></i>
                <p class="text-muted mt-3">No exercises added yet. Add your first exercise below.</p>
            </div>
        }
        @for (var i = 0; i < Exercises.Count; i++)
        {
            var idx = i;
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                        <i class="bi bi-grip-vertical text-muted" style="font-size: 1.2rem;"></i>
                        <input type="text" class="form-control flex-grow-1" style="min-width: 150px;" @bind="Exercises[idx].Name" placeholder="Exercise name (e.g., Bench Press)" />
                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveExercise(idx)">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-repeat text-muted"></i>
                            <label class="mb-0 fw-medium">Sets:</label>
                            <input type="number" class="form-control" style="width: 80px;" @bind="Exercises[idx].SetCount" min="1" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-hourglass-split text-muted"></i>
                            <label class="mb-0 fw-medium">Rest:</label>
                            <div class="input-group" style="width: 120px;">
                                <input type="number" class="form-control" @bind="Exercises[idx].RestIntervalSeconds" min="0" />
                                <span class="input-group-text">s</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <input type="text" class="form-control flex-grow-1" style="min-width: 200px; max-width: 400px;" @bind="NewExerciseName" placeholder="New exercise name" @onkeydown="AddExerciseKeydown" />
                <button type="button" class="btn btn-outline-primary" @onclick="AddExercise">
                    <i class="bi bi-plus-circle-fill me-2"></i>Add Exercise
                </button>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="Save" disabled="@(!CanSave)">
            <i class="bi bi-save-fill me-2"></i>Save Plan
        </button>
        <a href="/" class="btn btn-secondary">
            <i class="bi bi-x-circle me-2"></i>Cancel
        </a>
        @if (!IsNew)
        {
            <a href="/workout/@PlanId" class="btn btn-success">
                <i class="bi bi-play-fill me-2"></i>Start This Workout
            </a>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid? PlanId { get; set; }

    private string PlanName { get; set; } = "Workout";
    private int RestIntervalSeconds { get; set; } = 60;
    private int DefaultSetCount { get; set; } = 4;
    private List<ExercisePlan> Exercises { get; set; } = new();
    private string NewExerciseName { get; set; } = "";
    private bool IsNew => PlanId == null;

    private bool CanSave => !string.IsNullOrWhiteSpace(PlanName) && Exercises.Any() && Exercises.All(e => !string.IsNullOrWhiteSpace(e.Name));

    protected override async Task OnInitializedAsync()
    {
        if (PlanId.HasValue)
        {
            var plan = await PlanService.GetPlanAsync(PlanId.Value);
            if (plan != null)
            {
                PlanName = plan.Name;
                RestIntervalSeconds = plan.RestIntervalSeconds;
                DefaultSetCount = plan.DefaultSetCount;
                Exercises = plan.Exercises.OrderBy(e => e.Order).Select(e => new ExercisePlan 
                { 
                    Id = e.Id, 
                    Name = e.Name, 
                    SetCount = e.SetCount, 
                    Order = e.Order,
                    RestIntervalSeconds = e.RestIntervalSeconds
                }).ToList();
            }
        }
    }

    private void AddExercise()
    {
        if (string.IsNullOrWhiteSpace(NewExerciseName)) return;
        Exercises.Add(new ExercisePlan 
        { 
            Name = NewExerciseName.Trim(), 
            SetCount = DefaultSetCount, 
            Order = Exercises.Count,
            RestIntervalSeconds = RestIntervalSeconds
        });
        NewExerciseName = "";
    }

    private void AddExerciseKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddExercise();
        }
    }

    private void RemoveExercise(int index)
    {
        if (index >= 0 && index < Exercises.Count)
        {
            Exercises.RemoveAt(index);
            for (var i = 0; i < Exercises.Count; i++)
                Exercises[i].Order = i;
        }
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var plan = new WorkoutPlan
        {
            Id = PlanId ?? Guid.NewGuid(),
            Name = PlanName.Trim(),
            RestIntervalSeconds = RestIntervalSeconds,
            DefaultSetCount = DefaultSetCount,
            Exercises = Exercises.Select((e, i) => new ExercisePlan 
            { 
                Id = e.Id, 
                Name = e.Name.Trim(), 
                SetCount = e.SetCount, 
                Order = i,
                RestIntervalSeconds = e.RestIntervalSeconds
            }).ToList()
        };
        await PlanService.SavePlanAsync(plan);
        Navigation.NavigateTo("/");
    }
}
