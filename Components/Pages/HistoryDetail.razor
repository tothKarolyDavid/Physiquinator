@page "/history/{SessionId}"
@inject WorkoutHistoryRepository HistoryRepo
@inject NavigationManager Navigation

<div class="mb-3 mt-3 d-flex flex-wrap gap-2">
    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoHistoryList">
        <i class="bi bi-arrow-left me-1"></i>All sessions
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoHome">
        <i class="bi bi-house me-1"></i>Home
    </button>
</div>

@if (!_ready)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading</span>
        </div>
    </div>
}
else if (_session == null)
{
    <p class="text-danger mt-3">This workout session was not found.</p>
}
else
{
    <div class="card mb-3">
        <div class="card-header py-2">
            <span class="small fw-semibold"><i class="bi bi-clipboard2-data me-1"></i>Workout</span>
        </div>
        <div class="card-body py-3">
            <h1 class="h4 mb-2">@_session.PlanName</h1>
            <p class="text-muted small mb-1">
                <i class="bi bi-clock me-1"></i>Started @UiDateFormats.LocalDateTimeCompact(_session.StartedAtUtc)
            </p>
            @if (_session.EndedAtUtc != null)
            {
                <p class="text-muted small mb-0">
                    <i class="bi bi-check2-circle me-1"></i>Ended @UiDateFormats.LocalDateTimeCompact(_session.EndedAtUtc.Value)
                </p>
            }
            else
            {
                <p class="text-muted small mb-0"><i class="bi bi-hourglass-split me-1"></i>In progress</p>
            }
            @if (_planGuid is { } planId)
            {
                <div class="mt-3 pt-3 border-top">
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => GoPlan(planId)">
                        <i class="bi bi-pencil-square me-1"></i>Open plan
                    </button>
                </div>
            }
        </div>
    </div>

    @if (_planGuid is { } pg && _distinctExerciseNames.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header py-2">
                <span class="small fw-semibold"><i class="bi bi-graph-up-arrow me-1"></i>Progress by exercise</span>
            </div>
            <div class="card-body py-3">
                <p class="text-muted small mb-3">Open a chart for any exercise from this session.</p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var name in _distinctExerciseNames)
                    {
                        var exercise = name;
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill" title="@exercise" @onclick="() => GoExerciseProgress(pg, exercise)">
                            <i class="bi bi-bar-chart-line-fill me-1"></i>@exercise
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @if (_snapshot != null)
    {
        <div class="card mb-3">
            <div class="card-header py-2">
                <span class="small fw-semibold"><i class="bi bi-camera-fill me-1"></i>Plan when you trained</span>
            </div>
            <div class="card-body py-3">
                @foreach (var ex in _snapshot.Exercises.OrderBy(e => e.Order))
                {
                    <div class="history-detail-snapshot-row small d-flex flex-wrap justify-content-between align-items-baseline column-gap-2 row-gap-1">
                        <span class="fw-medium">@ex.Name</span>
                        <span class="text-muted">@ex.SetCount sets · @ex.RestIntervalSeconds s rest</span>
                    </div>
                }
            </div>
        </div>
    }

    @if (!_setRows.Any())
    {
        <div class="card mb-3">
            <div class="card-body py-4 text-center text-muted small mb-0">No sets logged for this session.</div>
        </div>
    }
    else
    {
        <div class="card mb-3 history-detail-table-card overflow-hidden">
            <div class="card-header py-2">
                <span class="small fw-semibold"><i class="bi bi-list-ul me-1"></i>Sets</span>
            </div>
            <div class="table-responsive history-table-wrap history-detail-sets-table">
                <table class="table table-sm table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Exercise</th>
                            <th>Set</th>
                            <th>Reps</th>
                            <th>kg</th>
                            <th>Time</th>
                            <th><abbr title="Rest after previous set">Rest</abbr></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _setRows)
                        {
                            <tr>
                                <td>@row.Log.ExerciseName</td>
                                <td>@(row.Log.SetIndex + 1)</td>
                                <td>@(row.Log.Reps?.ToString() ?? "—")</td>
                                <td>@(row.Log.WeightKg is { } w ? w.ToString("0.##") : "—")</td>
                                <td class="text-nowrap small">@UiDateFormats.LocalDateTimeCompact(row.Log.CompletedAtUtc)</td>
                                <td class="small text-muted">@(row.RestAfterPrevious ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-4 pt-3 border-top">
        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DeleteSessionClick">
            <i class="bi bi-trash me-1"></i>Delete this workout
        </button>
    </div>
}

@code {
    [Parameter]
    public string SessionId { get; set; } = "";

    private bool _ready;
    private WorkoutSessionLogEntity? _session;
    private WorkoutPlan? _snapshot;
    private List<SetRow> _setRows = new();
    private Guid? _planGuid;
    private List<string> _distinctExerciseNames = new();

    private record SetRow(WorkoutSetLogEntity Log, string? RestAfterPrevious);

    private void GoHistoryList() => Navigation.NavigateTo("/history");

    private void GoHome() => Navigation.NavigateTo("/");

    private void GoPlan(Guid planId) => Navigation.NavigateTo($"/plan/{planId}");

    private void GoExerciseProgress(Guid planId, string exerciseName) =>
        Navigation.NavigateTo($"/history/exercise-progress/{planId}/{Uri.EscapeDataString(exerciseName)}");

    protected override async Task OnParametersSetAsync()
    {
        _ready = false;
        var id = Uri.UnescapeDataString(SessionId ?? "");
        _session = string.IsNullOrWhiteSpace(id) ? null : await HistoryRepo.GetSessionAsync(id);
        _snapshot = WorkoutHistoryRepository.TryParsePlanSnapshot(_session?.PlanSnapshotJson);

        var sets = _session != null
            ? (await HistoryRepo.GetSetsForSessionAsync(_session.Id)).ToList()
            : new List<WorkoutSetLogEntity>();

        _setRows = BuildSetRows(sets);
        _planGuid = Guid.TryParse(_session?.WorkoutPlanId, out var g) ? g : null;
        _distinctExerciseNames = sets
            .Select(s => s.ExerciseName)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(n => n, StringComparer.OrdinalIgnoreCase)
            .ToList();
        _ready = true;
    }

    private static List<SetRow> BuildSetRows(IReadOnlyList<WorkoutSetLogEntity> orderedSets)
    {
        var list = new List<SetRow>();
        DateTime? previousUtc = null;
        foreach (var log in orderedSets)
        {
            string? rest = null;
            if (previousUtc != null)
            {
                var gap = log.CompletedAtUtc - previousUtc.Value;
                if (gap.TotalSeconds >= 0)
                    rest = FormatDuration(gap);
            }

            list.Add(new SetRow(log, rest));
            previousUtc = log.CompletedAtUtc;
        }

        return list;
    }

    private static string FormatDuration(TimeSpan gap)
    {
        if (gap.TotalHours >= 1)
            return $"{(int)gap.TotalHours}:{gap.Minutes:D2}:{gap.Seconds:D2}";
        if (gap.TotalMinutes >= 1)
            return $"{(int)gap.TotalMinutes}:{gap.Seconds:D2}";
        return $"{(int)gap.TotalSeconds}s";
    }

    private async Task DeleteSessionClick()
    {
        if (_session == null) return;

        var page = Application.Current?.Windows.FirstOrDefault()?.Page;
        if (page == null) return;

        var ok = await page.DisplayAlertAsync(
            "Delete workout",
            "Remove this session and all logged sets? This cannot be undone.",
            "Delete",
            "Cancel");

        if (!ok) return;

        await HistoryRepo.DeleteSessionAsync(_session.Id);
        Navigation.NavigateTo("/history");
    }
}
