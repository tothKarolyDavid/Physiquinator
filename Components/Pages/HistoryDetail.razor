@page "/history/{SessionId}"
@inject WorkoutHistoryRepository HistoryRepo
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageHeader Title="Session" OnBack="GoHistoryList">
    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="GoHome">Home</MudButton>
</PageHeader>

@if (!_ready)
{
    <LoadingCenter />
}
else if (_session == null)
{
    <MudAlert Severity="Severity.Error">This workout session was not found.</MudAlert>
}
else
{
    <MudStack Spacing="3" Class="app-page-with-actions">
        @if (_session.EndedAtUtc == null && _planGuid is { } activePlanId)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@(() => ContinueWorkout(activePlanId))">
                Continue workout
            </MudButton>
        }

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h5">@_session.PlanName</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Started @UiDateFormats.LocalDateTimeCompact(_session.StartedAtUtc)
            </MudText>
            @if (_session.EndedAtUtc != null)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Ended @UiDateFormats.LocalDateTimeCompact(_session.EndedAtUtc.Value)
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">In progress</MudText>
            }
            @if (_planGuid is { } planId)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mt-2" OnClick="@(() => GoPlan(planId))">
                    Open plan
                </MudButton>
            }
        </MudPaper>

        @if (_planGuid is { } pg && _distinctExerciseNames.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-2">Progress by exercise</MudText>
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    @foreach (var name in _distinctExerciseNames)
                    {
                        var exercise = name;
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(() => GoExerciseProgress(pg, exercise))">
                            @exercise
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

        @if (_snapshot != null)
        {
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-2">Plan when you trained</MudText>
                @foreach (var ex in _snapshot.Exercises.OrderBy(e => e.Order))
                {
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
                        <MudText Typo="Typo.body2">@ex.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@ex.SetCount sets · @ex.RestIntervalSeconds s rest</MudText>
                    </MudStack>
                }
            </MudPaper>
        }

        @if (!_setRows.Any())
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No sets logged for this session.</MudText>
        }
        else
        {
            <MudPaper Elevation="1">
                <MudText Typo="Typo.h6" Class="pa-3 pb-0">Sets</MudText>
                <MudTable Items="_setRows" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Exercise</MudTh>
                        <MudTh>Set</MudTh>
                        <MudTh>Reps</MudTh>
                        <MudTh>kg</MudTh>
                        <MudTh>Time</MudTh>
                        <MudTh>Rest</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Log.ExerciseName</MudTd>
                        <MudTd>@(context.Log.SetIndex + 1)</MudTd>
                        <MudTd>@(context.Log.Reps?.ToString() ?? "—")</MudTd>
                        <MudTd>@(context.Log.WeightKg is { } w ? w.ToString("0.##") : "—")</MudTd>
                        <MudTd>@UiDateFormats.LocalDateTimeCompact(context.Log.CompletedAtUtc)</MudTd>
                        <MudTd>@(context.RestAfterPrevious ?? "—")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteSessionClick">
            Delete this workout
        </MudButton>
    </MudStack>
}

@code {
    [Parameter]
    public string SessionId { get; set; } = "";

    private bool _ready;
    private WorkoutSessionLogEntity? _session;
    private WorkoutPlan? _snapshot;
    private List<SetRow> _setRows = new();
    private Guid? _planGuid;
    private List<string> _distinctExerciseNames = new();

    private record SetRow(WorkoutSetLogEntity Log, string? RestAfterPrevious);

    private void GoHistoryList() => Navigation.NavigateTo("/history");

    private void GoHome() => Navigation.NavigateTo("/");

    private void GoPlan(Guid planId) => Navigation.NavigateTo($"/plan/{planId}");

    private void ContinueWorkout(Guid planId) => Navigation.NavigateTo($"/workout/{planId}");

    private void GoExerciseProgress(Guid planId, string exerciseName) =>
        Navigation.NavigateTo($"/history/exercise-progress/{planId}/{Uri.EscapeDataString(exerciseName)}");

    protected override async Task OnParametersSetAsync()
    {
        _ready = false;
        var id = Uri.UnescapeDataString(SessionId ?? "");
        _session = string.IsNullOrWhiteSpace(id) ? null : await HistoryRepo.GetSessionAsync(id);
        _snapshot = WorkoutHistoryRepository.TryParsePlanSnapshot(_session?.PlanSnapshotJson);

        var sets = _session != null
            ? (await HistoryRepo.GetSetsForSessionAsync(_session.Id)).ToList()
            : new List<WorkoutSetLogEntity>();

        _setRows = BuildSetRows(sets);
        _planGuid = Guid.TryParse(_session?.WorkoutPlanId, out var g) ? g : null;
        _distinctExerciseNames = sets
            .Select(s => s.ExerciseName)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(n => n, StringComparer.OrdinalIgnoreCase)
            .ToList();
        _ready = true;
    }

    private static List<SetRow> BuildSetRows(IReadOnlyList<WorkoutSetLogEntity> orderedSets)
    {
        var list = new List<SetRow>();
        DateTime? previousUtc = null;
        foreach (var log in orderedSets)
        {
            string? rest = null;
            if (previousUtc != null)
            {
                var gap = log.CompletedAtUtc - previousUtc.Value;
                if (gap.TotalSeconds >= 0)
                    rest = FormatDuration(gap);
            }

            list.Add(new SetRow(log, rest));
            previousUtc = log.CompletedAtUtc;
        }

        return list;
    }

    private static string FormatDuration(TimeSpan gap)
    {
        if (gap.TotalHours >= 1)
            return $"{(int)gap.TotalHours}:{gap.Minutes:D2}:{gap.Seconds:D2}";
        if (gap.TotalMinutes >= 1)
            return $"{(int)gap.TotalMinutes}:{gap.Seconds:D2}";
        return $"{(int)gap.TotalSeconds}s";
    }

    private async Task DeleteSessionClick()
    {
        if (_session == null) return;

        var ok = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Delete workout",
            "Remove this session and all logged sets? This cannot be undone.",
            confirmText: "Delete",
            confirmColor: Color.Error);

        if (!ok) return;

        await HistoryRepo.DeleteSessionAsync(_session.Id);
        Navigation.NavigateTo("/history");
    }
}
