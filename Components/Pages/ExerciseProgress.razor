@page "/history/exercise-progress/{PlanId:guid}/{ExerciseName}"
@using System.Globalization
@using MudBlazor.Charts
@inject WorkoutHistoryRepository HistoryRepo
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation
@inject UserProfileService UserProfileService

<PageHeader Title="@_decodedExerciseName" OnBack="GoHistory" />

@if (!_ready)
{
    <LoadingCenter />
}
else
{
    <MudStack Spacing="3">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Logged performance on this plan — up to the last <strong>@_maxSessions</strong> sessions that include this exercise.
        </MudText>

        @if (!_rows.Any())
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No sets logged for this exercise on this plan yet.</MudText>
        }
        else
        {
            @if (_showChart)
            {
                <MudPaper Class="pa-3 exercise-progress-chart" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-1">Progression</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">
                        @GetChartCaption()
                    </MudText>
                    @if (_hasChartData)
                    {
                        <div class="exercise-progress-chart__plot">
                            <MudChart T="double"
                                      ChartType="ChartType.Line"
                                      ChartSeries="@_chartSeries"
                                      ChartLabels="@_chartLabels"
                                      ChartOptions="@_chartOptions"
                                      Width="100%"
                                      Height="@_chartHeightPx" />
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Log reps or weight on sets to see progression.
                        </MudText>
                    }
                </MudPaper>
            }

            <MudPaper Class="premium-table" Elevation="0">
                <MudTable Items="_rows" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        @if (_logType == ExerciseLogType.Duration)
                        {
                            <MudTh>Total Time</MudTh>
                            <MudTh>Sets</MudTh>
                        }
                        else if (_logType == ExerciseLogType.BodyweightReps)
                        {
                            <MudTh>Best Offset</MudTh>
                            <MudTh>Reps (Total)</MudTh>
                            <MudTh>Sets</MudTh>
                        }
                        else
                        {
                            <MudTh>kg (Best)</MudTh>
                            <MudTh>Reps (Total)</MudTh>
                            <MudTh>Sets</MudTh>
                        }
                        <MudTh Class="exercise-progress-table__action" />
                    </HeaderContent>
                    <RowTemplate>
                        @if (_logType == ExerciseLogType.Duration)
                        {
                            <MudTd>@(context.TotalReps)s</MudTd>
                            <MudTd>@context.SetCount</MudTd>
                        }
                        else
                        {
                            <MudTd>@FormatBestWeight(context.BestWeightKg)</MudTd>
                            <MudTd>@context.TotalReps</MudTd>
                            <MudTd>@context.SetCount</MudTd>
                        }
                        <MudTd Class="exercise-progress-table__action">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           Class="exercise-progress-table__open premium-btn"
                                           aria-label="Open session"
                                           OnClick="@(() => GoSession(context.SessionId))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    </MudStack>
}

@code {
    [Parameter]
    public Guid PlanId { get; set; }

    [Parameter]
    public string ExerciseName { get; set; } = "";

    private const int _maxSessions = 30;
    private ExerciseLogType _logType = ExerciseLogType.WeightAndReps;

    private bool _ready;
    private string _decodedExerciseName = "";
    private IReadOnlyList<ExerciseSessionProgressEntry> _rows = Array.Empty<ExerciseSessionProgressEntry>();
    private bool _showChart;
    private bool _hasChartData;
    private string[] _chartLabels = Array.Empty<string>();
    private sealed class ChartSeriesList : List<ChartSeries<double> > { }
    private ChartSeriesList _chartSeries = [];
    private LineChartOptions _chartOptions = new();
    private string _chartHeightPx = "280px";

    private const int _maxChartAxisLabels = 6;
    private double? _bodyweightKg;

    private void GoHistory() => Navigation.NavigateTo("/history");

    private void GoSession(string sessionId) =>
        Navigation.NavigateTo($"/history/{Uri.EscapeDataString(sessionId)}");

    protected override async Task OnParametersSetAsync()
    {
        _ready = false;
        _decodedExerciseName = Uri.UnescapeDataString(ExerciseName ?? "");
        _bodyweightKg = UserProfileService.GetActiveProfile().BodyweightKg;
        if (string.IsNullOrWhiteSpace(_decodedExerciseName))
        {
            _rows = Array.Empty<ExerciseSessionProgressEntry>();
            BuildChartData();
            _ready = true;
            return;
        }

        _rows = await HistoryRepo.GetExerciseSessionProgressAsync(PlanId, _decodedExerciseName, _maxSessions, _bodyweightKg);
        var plan = await PlanService.GetPlanAsync(PlanId);
        var ex = plan?.Exercises.FirstOrDefault(e => string.Equals(e.Name, _decodedExerciseName, StringComparison.OrdinalIgnoreCase));
        _logType = ex?.LogType ?? ExerciseLogType.WeightAndReps;
        BuildChartData();
        _ready = true;
    }

    private void BuildChartData()
    {
        _showChart = _rows.Count >= 2;
        if (!_showChart)
        {
            _chartLabels = Array.Empty<string>();
            _chartSeries = [];
            _hasChartData = false;
            return;
        }

        var chronological = _rows.Reverse().ToList();
        _chartLabels = BuildSparseChartLabels(
            chronological.Select(r => r.StartedAtUtc).ToList(),
            _maxChartAxisLabels);
        var isVolumePlot = _logType == ExerciseLogType.WeightAndReps || (_logType == ExerciseLogType.BodyweightReps && _bodyweightKg.HasValue);
        var values = isVolumePlot
            ? chronological.Select(r => r.TotalVolumeKg).ToArray()
            : chronological.Select(r => (double)r.TotalReps).ToArray();
        _hasChartData = values.Any(v => v > 0);
        _chartSeries = [ new ChartSeries<double>
        {
            Name = _logType == ExerciseLogType.Duration ? "Total Duration" : (isVolumePlot ? "Progression" : "Total Reps"),
            Data = values
        } ];

        var maxValue = values.DefaultIfEmpty(0).Max();
        var rotateXLabels = chronological.Count > 4;
        _chartHeightPx = rotateXLabels ? "300px" : "280px";
        _chartOptions = new LineChartOptions
        {
            YAxisRequireZeroPoint = false,
            ShowDataMarkers = false,
            MaxNumYAxisTicks = 5,
            YAxisToStringFunc = FormatYAxisTick,
            YAxisSuggestedMax = maxValue > 0 ? ChartAxisScale.SuggestYAxisMax(maxValue) : null,
            XAxisLabelRotation = rotateXLabels ? -35 : 0
        };
    }

    private string GetChartCaption()
    {
        if (_logType == ExerciseLogType.Duration)
        {
            return "Per set: duration in seconds.";
        }
        if (_logType == ExerciseLogType.BodyweightReps)
        {
            return _bodyweightKg.HasValue
                ? $"Per set: reps × (bodyweight [{_bodyweightKg.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg] + offset)."
                : "Per set: reps (bodyweight not set in settings).";
        }
        return "Per set: reps × kg when both are logged; otherwise reps or kg alone.";
    }

    private static string FormatYAxisTick(double value) =>
        value.ToString("0", CultureInfo.CurrentCulture);

    private static string[] BuildSparseChartLabels(IReadOnlyList<DateTime> datesUtc, int maxLabels)
    {
        var count = datesUtc.Count;
        if (count == 0)
            return Array.Empty<string>();

        maxLabels = Math.Clamp(maxLabels, 2, 12);
        var labels = new string[count];

        if (count <= maxLabels)
        {
            for (var i = 0; i < count; i++)
                labels[i] = UiDateFormats.LocalDateChartAxis(datesUtc[i]);
            return labels;
        }

        for (var tick = 0; tick < maxLabels; tick++)
        {
            var index = tick == maxLabels - 1
                ? count - 1
                : (int)Math.Round(tick * (count - 1) / (double)(maxLabels - 1));
            labels[index] = UiDateFormats.LocalDateChartAxis(datesUtc[index]);
        }

        return labels;
    }

    private string FormatBestWeight(double? weight)
    {
        if (_logType == ExerciseLogType.BodyweightReps)
        {
            if (weight == null || weight.Value == 0)
            {
                return _bodyweightKg.HasValue 
                    ? $"BW ({_bodyweightKg.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg)" 
                    : "BW";
            }
            if (weight.Value > 0)
            {
                return _bodyweightKg.HasValue 
                    ? $"BW + {weight.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg ({(weight.Value + _bodyweightKg.Value).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg)" 
                    : $"BW + {weight.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg";
            }
            return _bodyweightKg.HasValue 
                ? $"BW - {Math.Abs(weight.Value).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg ({(_bodyweightKg.Value - Math.Abs(weight.Value)).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg)" 
                : $"BW - {Math.Abs(weight.Value).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg";
        }
        return weight is { } w ? $"{w.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} kg" : "—";
    }
}
