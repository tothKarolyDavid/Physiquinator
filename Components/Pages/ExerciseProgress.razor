@page "/history/exercise-progress/{PlanId:guid}/{ExerciseName}"
@inject WorkoutHistoryRepository HistoryRepo
@inject NavigationManager Navigation

<PageHeader Title="@_decodedExerciseName" OnBack="GoHistory" />

@if (!_ready)
{
    <LoadingCenter />
}
else
{
    <MudStack Spacing="3">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Logged performance on this plan — up to the last <strong>@_maxSessions</strong> sessions that include this exercise.
        </MudText>

        @if (!_rows.Any())
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No sets logged for this exercise on this plan yet.</MudText>
        }
        else
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudTable Items="_rows" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh Class="text-end">Best kg</MudTh>
                        <MudTh Class="text-end">Total reps</MudTh>
                        <MudTh Class="text-end">Sets</MudTh>
                        <MudTh Class="text-end">Session</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@UiDateFormats.LocalDateCompact(context.StartedAtUtc)</MudTd>
                        <MudTd Class="text-end">@(context.BestWeightKg is { } w ? w.ToString("0.##") : "—")</MudTd>
                        <MudTd Class="text-end">@context.TotalReps</MudTd>
                        <MudTd Class="text-end">@context.SetCount</MudTd>
                        <MudTd Class="text-end">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => GoSession(context.SessionId))">
                                Open
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    </MudStack>
}

@code {
    [Parameter]
    public Guid PlanId { get; set; }

    [Parameter]
    public string ExerciseName { get; set; } = "";

    private const int _maxSessions = 30;

    private bool _ready;
    private string _decodedExerciseName = "";
    private IReadOnlyList<ExerciseSessionProgressEntry> _rows = Array.Empty<ExerciseSessionProgressEntry>();

    private void GoHistory() => Navigation.NavigateTo("/history");

    private void GoSession(string sessionId) =>
        Navigation.NavigateTo($"/history/{Uri.EscapeDataString(sessionId)}");

    protected override async Task OnParametersSetAsync()
    {
        _ready = false;
        _decodedExerciseName = Uri.UnescapeDataString(ExerciseName ?? "");
        if (string.IsNullOrWhiteSpace(_decodedExerciseName))
        {
            _rows = Array.Empty<ExerciseSessionProgressEntry>();
            _ready = true;
            return;
        }

        _rows = await HistoryRepo.GetExerciseSessionProgressAsync(PlanId, _decodedExerciseName, _maxSessions);
        _ready = true;
    }
}
