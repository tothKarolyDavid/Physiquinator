@page "/history"
@inject WorkoutHistoryRepository HistoryRepo
@inject NavigationManager Navigation
<MudStack Spacing="3">
    <PageHeader Title="Workout history" ShowBack="false" />
    <MudText Typo="Typo.body2" Class="mud-text-secondary">
        Tap a day on the grid to filter the list. Each square is one calendar day; weeks run Monday–Sunday.
    </MudText>

    @if (_sessions == null || _activityByDay == null || _listSessions == null || _summary == null)
    {
        <LoadingCenter Label="Loading history…" />
    }
    else
    {
        <MudTextField T="string"
                      Value="_searchText"
                      ValueChanged="OnSearchTextChanged"
                      Placeholder="Search by plan name..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true"
                      Variant="Variant.Outlined"
                      Class="mb-2" />

        <MudPaper Class="pa-4 history-heatmap-panel" Elevation="1">
            <ActivityHeatmap CountsByDay="_activityByDay"
                             Weeks="@HeatmapWeeks"
                             EndLocal="@_heatmapEndLocal"
                             SelectedDay="_selectedDay"
                             SelectedDayChanged="OnSelectedDayChanged" />
        </MudPaper>

        <div class="history-stats">
            <MudPaper Class="history-stat" Elevation="0">
                <span class="history-stat__value">@_summary.CurrentStreakWorkoutDays</span>
                <span class="history-stat__label">Streak</span>
            </MudPaper>
            <MudPaper Class="history-stat" Elevation="0">
                <span class="history-stat__value">@_summary.LongestStreakWorkoutDays</span>
                <span class="history-stat__label">Longest streak</span>
            </MudPaper>
            <MudPaper Class="history-stat" Elevation="0">
                <span class="history-stat__value">@_summary.ThisWeekSessionCount</span>
                <span class="history-stat__label">This week</span>
            </MudPaper>
            <MudPaper Class="history-stat" Elevation="0">
                <span class="history-stat__value">@_summary.LastWeekSessionCount</span>
                <span class="history-stat__label">Last week</span>
            </MudPaper>
        </div>

        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            A streak day is any calendar day with at least one logged session.
        </MudText>

        @if (_selectedDay != null)
        {
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Primary" OnClose="ClearDayFilter">
                    @(_selectedDay.HasValue ? UiDateFormats.DateOnlyCompact(_selectedDay.Value) : "")
                </MudChip>
                @if (!_listSessions.Any())
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">— none logged.</MudText>
                }
            </MudStack>
        }

        @if (!_sessions.Any())
        {
            <EmptyState Message="No logged workouts yet. Start a plan from home."
                        Icon="@Icons.Material.Outlined.History" />
        }
        else if (!_listSessions.Any() && _selectedDay != null)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Pick another day or clear the filter.
            </MudText>
        }
        else
        {
            <div class="history-session-list">
                @foreach (var s in _listSessions)
                {
                    var sid = s.Id;
                    <div @key="s.Id" class="history-session-card" @onclick="@(() => OpenSession(sid))">
                        <div class="history-session-card__inner">
                            <div class="history-session-card__left">
                                <div class="history-session-card__info">
                                    <span class="history-session-card__title">@s.PlanName</span>
                                    <span class="history-session-card__subtitle">
                                        @UiDateFormats.LocalDateTimeCompact(s.StartedAtUtc)
                                        @if (s.EndedAtUtc != null)
                                        {
                                            <span> · @UiDateFormats.LocalDateTimeCompact(s.EndedAtUtc.Value)</span>
                                        }
                                        else
                                        {
                                            <span class="history-session-card__badge-inprogress">In progress</span>
                                        }
                                    </span>
                                </div>
                            </div>
                            <div class="history-session-card__right">
                                @if (s.EndedAtUtc == null && Guid.TryParse(s.WorkoutPlanId, out var continuePlanId))
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Class="history-session-card__continue-btn"
                                                   OnClick="@(() => ContinueWorkout(continuePlanId))">
                                            Continue
                                        </MudButton>
                                    </div>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="history-session-card__chevron" />
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</MudStack>

@code {
    private const int HeatmapWeeks = 53;
 
    private IReadOnlyList<WorkoutSessionLogEntity>? _sessions;
    private IReadOnlyList<WorkoutSessionLogEntity>? _listSessions;
    private IReadOnlyList<WorkoutSessionLogEntity>? _daySessions;
    private IReadOnlyDictionary<DateOnly, int>? _activityByDay;
    private DateOnly _heatmapEndLocal;
    private WorkoutDaySummary? _summary;
    private DateOnly? _selectedDay;
    private string _searchText = "";
 
    private void OpenSession(string sessionId) =>
        Navigation.NavigateTo($"/history/{Uri.EscapeDataString(sessionId)}");
 
    private void ContinueWorkout(Guid planId) =>
        Navigation.NavigateTo($"/workout/{planId}");
 
    protected override async Task OnInitializedAsync()
    {
        _heatmapEndLocal = DateOnly.FromDateTime(DateTime.Today);
        var (utcStart, utcEndExclusive) = ActivityHeatmap.GetHeatmapQueryUtcBounds(_heatmapEndLocal, HeatmapWeeks);
        var gridStart = ActivityHeatmap.GetMondayOfWeek(_heatmapEndLocal).AddDays(-7 * (HeatmapWeeks - 1));
 
        var sessionsTask = HistoryRepo.GetRecentSessionsAsync(100);
        var activityTask = HistoryRepo.GetSessionCountsByLocalDayAsync(utcStart, utcEndExclusive);
        await Task.WhenAll(sessionsTask, activityTask);
 
        _sessions = await sessionsTask;
        _activityByDay = await activityTask;
        _summary = WorkoutDayStats.Compute(_activityByDay, _heatmapEndLocal, gridStart);
        await UpdateSessionsListAsync();
    }

    private async Task UpdateSessionsListAsync()
    {
        if (_sessions == null) return;

        IEnumerable<WorkoutSessionLogEntity> source;
        if (_selectedDay == null)
        {
            source = _sessions;
        }
        else
        {
            if (_daySessions == null)
            {
                _daySessions = await HistoryRepo.GetSessionsForLocalDayAsync(_selectedDay.Value);
            }
            source = _daySessions;
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var query = _searchText.Trim();
            source = source.Where(s => s.PlanName.Contains(query, StringComparison.OrdinalIgnoreCase));
        }

        _listSessions = source.ToList();
    }

    private async Task OnSearchTextChanged(string text)
    {
        _searchText = text;
        await UpdateSessionsListAsync();
    }
 
    private async Task OnSelectedDayChanged(DateOnly? day)
    {
        _selectedDay = day;
        _daySessions = null;
        await UpdateSessionsListAsync();
        StateHasChanged();
    }
 
    private Task ClearDayFilter() => OnSelectedDayChanged(null);
}
