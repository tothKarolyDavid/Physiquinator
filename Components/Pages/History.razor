@page "/history"
@inject WorkoutHistoryRepository HistoryRepo
@inject NavigationManager Navigation

<div class="mb-3 mt-3">
    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoHome">
        <i class="bi bi-arrow-left me-2"></i>Back
    </button>
</div>

<h1 class="h4 mb-1"><i class="bi bi-clock-history me-2"></i>Workout history</h1>
<p class="small history-page-lead mb-3">Tap a day on the grid to filter the list below. Each square is one local calendar day; weeks run Monday–Sunday.</p>

@if (_sessions == null || _activityByDay == null || _listSessions == null || _summary == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading</span>
        </div>
    </div>
}
else
{
    <div class="history-heatmap-panel">
        <ActivityHeatmap CountsByDay="_activityByDay"
                         Weeks="@HeatmapWeeks"
                         EndLocal="@_heatmapEndLocal"
                         SelectedDay="_selectedDay"
                         SelectedDayChanged="OnSelectedDayChanged" />
    </div>

    <div class="history-stat-grid">
        <div class="history-stat">
            <div class="history-stat-value">@_summary.CurrentStreakWorkoutDays</div>
            <div class="history-stat-primary">Active day streak</div>
        </div>
        <div class="history-stat">
            <div class="history-stat-value">@_summary.LongestStreakWorkoutDays</div>
            <div class="history-stat-primary">Longest streak on calendar</div>
        </div>
        <div class="history-stat">
            <div class="history-stat-value">@_summary.ThisWeekSessionCount</div>
            <div class="history-stat-primary">Sessions this week</div>
        </div>
        <div class="history-stat">
            <div class="history-stat-value">@_summary.LastWeekSessionCount</div>
            <div class="history-stat-primary">Sessions last week</div>
        </div>
    </div>
    <p class="history-stat-footnote small mb-3">A streak day is any calendar day with at least one logged session. Session counts include every workout in that Monday–Sunday week (local time).</p>

    @if (_selectedDay != null)
    {
        <div class="history-day-filter-banner mb-3 flex-column flex-sm-row align-items-stretch align-items-sm-center">
            <span>
                Showing sessions on <strong>@UiDateFormats.DateOnlyCompact(_selectedDay.Value)</strong>
                @if (!_listSessions.Any())
                {
                    <span class="text-muted"> — none logged.</span>
                }
            </span>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ClearDayFilter">Clear filter</button>
        </div>
    }

    @if (!_sessions.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem; color: var(--tn-accent); opacity: 0.35;"></i>
            <p class="text-muted mt-3 mb-0">No logged workouts yet. Start a plan from home to build your history.</p>
        </div>
    }
    else if (!_listSessions.Any() && _selectedDay != null)
    {
        <p class="text-muted small mb-0">Pick another day on the heatmap or clear the filter to see recent sessions.</p>
    }
    else
    {
        <div class="card overflow-hidden history-session-card">
            <div class="list-group list-group-flush">
                @foreach (var s in _listSessions)
                {
                    var sid = s.Id;
                    <button type="button"
                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2 py-3 w-100 text-start"
                            @onclick="() => OpenSession(sid)">
                        <div class="min-w-0">
                            <div class="fw-semibold text-truncate">@s.PlanName</div>
                            <small class="text-muted text-break">
                                @UiDateFormats.LocalDateTimeCompact(s.StartedAtUtc)
                                @if (s.EndedAtUtc != null)
                                {
                                    <span class="text-nowrap"> · @UiDateFormats.LocalDateTimeCompact(s.EndedAtUtc.Value)</span>
                                }
                                else
                                {
                                    <span> · in progress</span>
                                }
                            </small>
                        </div>
                        <i class="bi bi-chevron-right text-muted flex-shrink-0 mt-1"></i>
                    </button>
                }
            </div>
        </div>
    }
}

@code {
    private const int HeatmapWeeks = 53;

    private IReadOnlyList<WorkoutSessionLogEntity>? _sessions;
    private IReadOnlyList<WorkoutSessionLogEntity>? _listSessions;
    private IReadOnlyDictionary<DateOnly, int>? _activityByDay;
    private DateOnly _heatmapEndLocal;
    private WorkoutDaySummary? _summary;
    private DateOnly? _selectedDay;

    private void GoHome() => Navigation.NavigateTo("/");

    private void OpenSession(string sessionId) =>
        Navigation.NavigateTo($"/history/{Uri.EscapeDataString(sessionId)}");

    protected override async Task OnInitializedAsync()
    {
        _heatmapEndLocal = DateOnly.FromDateTime(DateTime.Today);
        var (utcStart, utcEndExclusive) = ActivityHeatmap.GetHeatmapQueryUtcBounds(_heatmapEndLocal, HeatmapWeeks);
        var gridStart = ActivityHeatmap.GetMondayOfWeek(_heatmapEndLocal).AddDays(-7 * (HeatmapWeeks - 1));

        var sessionsTask = HistoryRepo.GetRecentSessionsAsync(100);
        var activityTask = HistoryRepo.GetSessionCountsByLocalDayAsync(utcStart, utcEndExclusive);
        await Task.WhenAll(sessionsTask, activityTask);

        _sessions = await sessionsTask;
        _activityByDay = await activityTask;
        _summary = WorkoutDayStats.Compute(_activityByDay, _heatmapEndLocal, gridStart);
        _listSessions = _sessions;
    }

    private async Task OnSelectedDayChanged(DateOnly? day)
    {
        _selectedDay = day;
        if (_sessions == null) return;

        if (day == null)
            _listSessions = _sessions;
        else
            _listSessions = await HistoryRepo.GetSessionsForLocalDayAsync(day.Value);

        StateHasChanged();
    }

    private Task ClearDayFilter() => OnSelectedDayChanged(null);
}
