@page "/workout/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject WorkoutSessionService SessionService
@inject RestNotificationService RestNotifications
@inject RestAlertSettingsService RestAlertSettings
@inject WorkoutHistoryRepository HistoryRepository
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageHeader Title="@(SessionService.CurrentPlan?.Name ?? "Workout")" OnBack="ConfirmLeaveWorkoutInProgress" />

@if (SessionService.CurrentPlan == null)
{
    <EmptyState Message="No active workout. Start a plan from home."
                Icon="@Icons.Material.Outlined.Warning">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Go home</MudButton>
    </EmptyState>
}
else
{
    <MudStack Spacing="3">
        @if (SessionService.IsResting || _isRestComplete)
        {
            <MudPaper Class="@RestTimerPanelClass" Elevation="2">
                        <div class="rest-timer-active">
                            <div class="rest-timer-display" aria-live="polite" aria-label="@RestTimerDisplayAriaLabel">
                                @if (_isRestComplete)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check"
                                             Class="rest-timer-check"
                                             aria-hidden="true" />
                                }
                                else
                                {
                                    <div class="rest-timer-digits @RestDigitsClass @(SessionService.RestSecondsRemaining < 60 ? "rest-timer-digits--seconds-only" : "") @(SessionService.RestSecondsRemaining < 10 ? "rest-timer-digits--single-digit" : "")" role="timer">
                                        <span class="rest-timer-unit rest-timer-unit--minutes">@FormatMinutes(SessionService.RestSecondsRemaining)</span>
                                        <span class="rest-timer-separator">:</span>
                                        <span class="rest-timer-unit rest-timer-unit--seconds-tens">@FormatSecondsTens(SessionService.RestSecondsRemaining)</span>
                                        <span class="rest-timer-unit rest-timer-unit--seconds-units">@FormatSecondsUnits(SessionService.RestSecondsRemaining)</span>
                                    </div>
                                }
                            </div>

                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="4" Class="rest-timer-controls">
                                @if (_isRestComplete)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Replay"
                                                   Color="Color.Default"
                                                   aria-label="Reset rest"
                                                   OnClick="ResetRest"
                                                   Size="Size.Large" />
                                    <div class="rest-timer-controls__slot" aria-hidden="true"></div>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="SkipRest"
                                               aria-label="Continue to next set"
                                               Size="Size.Large">
                                        Continue
                                    </MudButton>
                                }
                                else
                                {
                                    @if (SessionService.IsRestPaused)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                                       Color="Color.Success"
                                                       aria-label="Resume rest"
                                                       OnClick="ResumeRest"
                                                       Size="Size.Large" />
                                    }
                                    else
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Pause"
                                                       Color="Color.Info"
                                                       aria-label="Pause rest"
                                                       OnClick="PauseRest"
                                                       Size="Size.Large" />
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.Replay"
                                                   Color="Color.Default"
                                                   aria-label="Reset rest"
                                                   OnClick="ResetRest"
                                                   Size="Size.Large" />
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="SkipRest"
                                               Size="Size.Large">
                                        Skip
                                    </MudButton>
                                }
                            </MudStack>

                            <div class="rest-timer-edge-track" aria-hidden="true">
                                <div class="rest-timer-edge-fill @RestTimerEdgeFillClass"
                                     style="width: @(RestTimerEdgeFillWidth)%"></div>
                            </div>
                        </div>
            </MudPaper>
        }

        <div class="workout-exercise-layout">
            @{
                var plan = SessionService.CurrentPlan;
                var upcoming = new List<(int Index, ExercisePlan Exercise, int CompletedCount)>();
                var completed = new List<(int Index, ExercisePlan Exercise, int CompletedCount)>();

                for (int e = 0; e < plan.Exercises.Count; e++)
                {
                    var exerciseIndex = e;
                    var exercise = plan.Exercises[e];
                    var completedSetsCount = 0;
                    for (var si = 0; si < exercise.SetCount; si++)
                    {
                        if (SessionService.IsSetCompleted(exerciseIndex, si))
                            completedSetsCount++;
                    }

                    if (completedSetsCount == exercise.SetCount)
                        completed.Add((exerciseIndex, exercise, completedSetsCount));
                    else
                        upcoming.Add((exerciseIndex, exercise, completedSetsCount));
                }
            }

            @foreach (var item in upcoming)
            {
                var exerciseIndex = item.Index;
                var exercise = item.Exercise;
                var completedSetsCount = item.CompletedCount;
                var isExpanded = _activeExerciseIndex == exerciseIndex;

                <MudCard Class="@($"mb-3 exercise-accordion-card {(isExpanded ? "exercise-accordion-card--expanded" : "")}")" @key="exercise.Id">
                    <div class="exercise-accordion-header" @onclick="@(() => ToggleAccordion(exerciseIndex))">
                        <div class="header-left">
                            <span class="exercise-order-badge mr-2">@(exerciseIndex + 1)</span>
                            <MudText Typo="Typo.h6" Class="exercise-name font-weight-bold">@exercise.Name</MudText>
                        </div>
                        <div class="header-right">
                            <span class="set-progress-text">@completedSetsCount / @exercise.SetCount sets</span>
                            <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Class="ml-2" />
                        </div>
                    </div>

                    @if (isExpanded)
                    {
                        <MudCardContent Class="pt-0">
                            <MudProgressLinear Color="Color.Primary" Value="@GetProgressValue(completedSetsCount, exercise.SetCount)" Class="mb-3" />
                            
                            @{
                                var activeSetIndex = _activeSetIndices.GetValueOrDefault(exerciseIndex, 0);
                                if (activeSetIndex >= exercise.SetCount)
                                {
                                    activeSetIndex = 0;
                                }
                            }

                            <div class="set-logging-rows">
                                @{
                                    var setIndex = activeSetIndex;
                                    var inputKey = (exerciseIndex, setIndex);
                                    (double? Weight, int? Reps) inputs = _setInputs.GetValueOrDefault(inputKey, (exercise.DefaultWeightKg ?? 0.0, exercise.DefaultReps ?? 10));

                                    var defaultWeight = _originalValues.TryGetValue(inputKey, out var origVal) 
                                        ? origVal.Weight 
                                        : (inputs.Weight ?? exercise.DefaultWeightKg ?? 0.0);
                                             
                                    var defaultReps = _originalValues.TryGetValue(inputKey, out origVal) 
                                        ? origVal.Reps 
                                        : (inputs.Reps ?? exercise.DefaultReps ?? 10);
                                }

                                <div class="set-active-panel">
                                    <div class="set-stepper-rows">
                                        <SetMetricStepper Value="@inputs.Weight"
                                                          ValueChanged="@(val => HandleWeightStepperChanged(exerciseIndex, setIndex, val))"
                                                          Step="2.5"
                                                          Min="0"
                                                          IsInteger="false"
                                                          Format="0.##"
                                                          Compact="true"
                                                          Unit="kg"
                                                          Placeholder="@defaultWeight" />
                                        <SetMetricStepper Value="@((double?)inputs.Reps)"
                                                          ValueChanged="@(val => HandleRepsStepperChanged(exerciseIndex, setIndex, val))"
                                                          Step="1"
                                                          Min="1"
                                                          IsInteger="true"
                                                          Format="0"
                                                          Compact="true"
                                                          Unit="reps"
                                                          Placeholder="@((double)defaultReps)" />
                                    </div>
                                    <button type="button"
                                            class="log-set-btn"
                                            @onclick="@(() => ToggleSetComplete(exerciseIndex, setIndex))"
                                            disabled="@_isCompleting">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-1" />
                                        Log Set
                                    </button>
                                </div>
                            </div>
                        </MudCardContent>
                    }
                </MudCard>
            }

            @if (completed.Any())
            {
                <div class="workout-completed-divider-title mt-4 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Class="mr-1 completed-icon" Size="Size.Small" />
                    <MudText Typo="Typo.overline" Color="Color.Success" Class="font-weight-bold">Completed</MudText>
                </div>
                
                @foreach (var item in completed)
                {
                    var exerciseIndex = item.Index;
                    var exercise = item.Exercise;
                    var completedSetsCount = item.CompletedCount;
                    var isExpanded = _activeExerciseIndex == exerciseIndex;

                    <MudCard Class="@($"mb-3 exercise-accordion-card exercise-accordion-card--completed {(isExpanded ? "exercise-accordion-card--expanded" : "")}")" @key="exercise.Id">
                        <div class="exercise-accordion-header" @onclick="@(() => ToggleAccordion(exerciseIndex))">
                            <div class="header-left">
                                <span class="completed-icon mr-2" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                                        <defs>
                                            <linearGradient id="chk-grad" x1="0" y1="0" x2="1" y2="1">
                                                <stop offset="0%" stop-color="#34d399"/>
                                                <stop offset="100%" stop-color="#059669"/>
                                            </linearGradient>
                                        </defs>
                                        <circle cx="11" cy="11" r="11" fill="url(#chk-grad)"/>
                                        <polyline points="6.5,11.5 9.5,14.5 15.5,8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </span>
                                <MudText Typo="Typo.h6" Class="exercise-name font-weight-bold text-decoration-line-through">@exercise.Name</MudText>
                            </div>
                            <div class="header-right">
                                <span class="set-progress-text text-success">@completedSetsCount / @exercise.SetCount sets</span>
                                <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Class="ml-2" />
                            </div>
                        </div>

                        @if (isExpanded)
                        {
                            <MudCardContent Class="pt-0">
                                <MudProgressLinear Color="Color.Success" Value="100" Class="mb-3" />
                                
                                <div class="set-logging-rows">
                                    @for (var si = 0; si < exercise.SetCount; si++)
                                    {
                                        var setIndex = si;
                                        var inputKey = (exerciseIndex, setIndex);
                                        (double? Weight, int? Reps) inputs = _setInputs.GetValueOrDefault(inputKey, (exercise.DefaultWeightKg ?? 0.0, exercise.DefaultReps ?? 10));
                                        
                                        var finalWeight = inputs.Weight ?? exercise.DefaultWeightKg ?? 0.0;
                                        var finalReps = inputs.Reps ?? exercise.DefaultReps ?? 10;

                                        <div class="set-summary-row">
                                            <span class="set-number-label">Set @(setIndex + 1)</span>
                                            <span class="set-values">@finalWeight.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) kg × @finalReps reps</span>
                                            <button type="button" 
                                                    class="log-check-btn log-check-btn--completed"
                                                    @onclick="@(() => ToggleSetComplete(exerciseIndex, setIndex))"
                                                    disabled="@_isCompleting">
                                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                            </button>
                                        </div>
                                    }
                                </div>
                            </MudCardContent>
                        }
                    </MudCard>
                }
            }

            @if (!UpcomingExercises.Any() && DoneExercises.Any())
            {
                <MudAlert Severity="Severity.Success" Class="mt-2">Workout complete!</MudAlert>
            }
        </div>

        <MudStack Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       FullWidth="true"
                       Class="workout-end-btn"
                       OnClick="EndWorkoutClick">
                End workout
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       FullWidth="true"
                       OnClick="DiscardWorkoutClick">
                Discard workout
            </MudButton>
        </MudStack>
    </MudStack>

}


@code {
    [Parameter]
    public Guid PlanId { get; set; }

    [SupplyParameterFromQuery(Name = "forceNew")]
    public bool ForceNew { get; set; }

    private bool _isRestComplete;
    private int _lastRestDurationSeconds;
    private Guid? _loadedPlanId;
    private bool _loadedForceNew;
    private IJSObjectReference? _audioModule;
    private bool _isCompleting;
    private bool _disposed;
    private DotNetObjectReference<Workout>? _dotNetRef;
    private string? _historySessionId;
    private bool _completedExpanded;
    private Snackbar? _undoSnackbar;

    private Dictionary<(int ExIdx, int SetIdx), (double? Weight, int? Reps)> _setInputs = new();
    private Dictionary<(int ExIdx, int SetIdx), (double Weight, int Reps)> _originalValues = new();
    private int _activeExerciseIndex = 0;
    private Dictionary<int, int> _activeSetIndices = new();

    private record ExerciseProgress(string ExerciseName, int ExerciseIndex, int CompletedSets, int TotalSets);

    private List<ExerciseProgress> DoneExercises => GetExerciseProgress(completed: true);
    private List<ExerciseProgress> UpcomingExercises => GetExerciseProgress(completed: false);

    protected override async Task OnInitializedAsync()
    {
        SessionService.RestCompletedWhileBackground += OnSessionRestCompletedWhileBackground;

        _dotNetRef = DotNetObjectReference.Create(this);

        try
        {
            _audioModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/workoutTimer.js");
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }

        await EnsureWorkoutStartedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_disposed) return;

        if (_loadedPlanId == PlanId && _loadedForceNew == ForceNew)
            return;

        _loadedPlanId = PlanId;
        _loadedForceNew = ForceNew;
        await EnsureWorkoutStartedAsync();
    }

    private async Task EnsureWorkoutStartedAsync()
    {
        var plan = await PlanService.GetPlanAsync(PlanId);
        if (_disposed || plan == null)
            return;

        if (RestAlertSettings.Enabled)
            await RestNotifications.EnsurePermissionAsync();

        if (!ForceNew)
        {
            var open = await HistoryRepository.GetInProgressSessionForPlanAsync(PlanId);
            if (open != null)
            {
                var workoutPlan = WorkoutHistoryRepository.TryParsePlanSnapshot(open.PlanSnapshotJson) ?? plan;
                var sets = await HistoryRepository.GetSetsForSessionAsync(open.Id);
                var completions = sets.Select(s => new SetCompletion(s.ExerciseIndex, s.SetIndex));
                SessionService.ResumeWorkout(workoutPlan, completions);
                _historySessionId = open.Id;
                await InitializeWorkoutStateAsync(workoutPlan);
                return;
            }
        }
        else
        {
            var open = await HistoryRepository.GetInProgressSessionForPlanAsync(PlanId);
            if (open != null)
                await HistoryRepository.EndSessionAsync(open.Id);
        }

        SessionService.StartWorkout(plan);
        var snapshot = PlanService.SerializePlanToJson(plan);
        _historySessionId = await HistoryRepository.BeginSessionAsync(plan.Id, plan.Name, snapshot);
        await InitializeWorkoutStateAsync(plan);
    }

    private async Task InitializeWorkoutStateAsync(WorkoutPlan plan)
    {
        _setInputs.Clear();
        _activeSetIndices.Clear();
        int firstUncompletedExIdx = -1;

        for (int e = 0; e < plan.Exercises.Count; e++)
        {
            var exercise = plan.Exercises[e];
            var lastMetrics = await HistoryRepository.GetLatestSetMetricsForExerciseAsync(plan.Id, exercise.Name);
            var initialReps = lastMetrics?.Reps ?? exercise.DefaultReps ?? 10;
            var initialWeight = lastMetrics?.WeightKg ?? exercise.DefaultWeightKg ?? 0;

            for (int s = 0; s < exercise.SetCount; s++)
            {
                _setInputs[(e, s)] = (initialWeight, initialReps);
            }

            int firstUncompletedSetIdx = -1;
            bool exerciseDone = true;
            for (int s = 0; s < exercise.SetCount; s++)
            {
                if (!SessionService.IsSetCompleted(e, s))
                {
                    exerciseDone = false;
                    if (firstUncompletedSetIdx == -1)
                    {
                        firstUncompletedSetIdx = s;
                    }
                }
            }

            _activeSetIndices[e] = firstUncompletedSetIdx == -1 ? 0 : firstUncompletedSetIdx;

            if (!exerciseDone && firstUncompletedExIdx == -1)
            {
                firstUncompletedExIdx = e;
            }
        }

        if (_historySessionId != null)
        {
            var currentSets = await HistoryRepository.GetSetsForSessionAsync(_historySessionId);
            foreach (var set in currentSets)
            {
                _setInputs[(set.ExerciseIndex, set.SetIndex)] = (set.WeightKg ?? 0, set.Reps ?? 0);
            }

            // Re-evaluate first uncompleted set index after loading session sets
            for (int e = 0; e < plan.Exercises.Count; e++)
            {
                var exercise = plan.Exercises[e];
                int firstUncompletedSetIdx = -1;
                for (int s = 0; s < exercise.SetCount; s++)
                {
                    if (!SessionService.IsSetCompleted(e, s))
                    {
                        firstUncompletedSetIdx = s;
                        break;
                    }
                }
                _activeSetIndices[e] = firstUncompletedSetIdx == -1 ? 0 : firstUncompletedSetIdx;
            }
        }

        _activeExerciseIndex = firstUncompletedExIdx == -1 ? 0 : firstUncompletedExIdx;
    }

    private List<ExerciseProgress> GetExerciseProgress(bool completed)
    {
        var plan = SessionService.CurrentPlan;
        if (plan == null) return [];

        var completedSetsSet = SessionService.CompletedSets.ToHashSet();
        var list = new List<ExerciseProgress>();

        for (var ei = 0; ei < plan.Exercises.Count; ei++)
        {
            var ex = plan.Exercises[ei];
            var completedSets = 0;

            for (var si = 0; si < ex.SetCount; si++)
            {
                if (completedSetsSet.Contains(new SetCompletion(ei, si)))
                    completedSets++;
            }

            var isFullyCompleted = completedSets == ex.SetCount;
            var hasAnySets = completedSets > 0;

            if (completed)
            {
                if (hasAnySets)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
            else
            {
                if (!isFullyCompleted)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
        }
        return list;
    }

    private string RestTimerPanelClass =>
        _isRestComplete
            ? "rest-timer-panel rest-timer-panel--active rest-timer-panel--complete"
            : "rest-timer-panel rest-timer-panel--active";

    private double RestProgressValue
    {
        get
        {
            var total = SessionService.ActiveRestDurationSeconds;
            if (total <= 0) return 0;
            var elapsed = total - SessionService.RestSecondsRemaining;
            return Math.Clamp(elapsed * 100.0 / total, 0, 100);
        }
    }

    private string RestDigitsClass =>
        SessionService.IsRestPaused
            ? "rest-timer-digits--paused"
            : SessionService.RestSecondsRemaining <= 3 && !SessionService.IsRestPaused
                ? "rest-timer-digits--urgent"
                : "";

    private string RestEdgeFillClass =>
        SessionService.IsRestPaused
            ? "rest-timer-edge-fill--paused"
            : SessionService.RestSecondsRemaining <= 3
                ? "rest-timer-edge-fill--urgent"
                : "";

    private string RestTimerAriaLabel =>
        SessionService.IsRestPaused
            ? $"Rest paused, {FormatTime(SessionService.RestSecondsRemaining)} remaining"
            : $"Rest, {FormatTime(SessionService.RestSecondsRemaining)} remaining";

    private string RestTimerDisplayAriaLabel =>
        _isRestComplete ? "Rest complete" : RestTimerAriaLabel;

    private string RestTimerEdgeFillClass => _isRestComplete ? "" : RestEdgeFillClass;

    private string RestTimerEdgeFillWidth =>
        _isRestComplete
            ? "100"
            : RestProgressValue.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    private async Task ConfirmLeaveWorkoutInProgress()
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Leave workout?",
            "Your progress is saved. You can continue this workout from home.",
            confirmText: "Leave",
            cancelText: "Stay",
            confirmColor: Color.Primary);
        if (confirmed)
            await LeaveWorkoutInProgress();
    }

    private async Task LeaveWorkoutInProgress()
    {
        if (_disposed) return;

        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();
        SessionService.EndWorkout();
        Navigation.NavigateTo("/");
    }

    private async Task EndWorkoutClick()
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "End workout?",
            "Save this session and return home?",
            confirmText: "End",
            confirmColor: Color.Error);
        if (confirmed)
            await EndWorkout();
    }

    private async Task DiscardWorkoutClick()
    {
        var planName = SessionService.CurrentPlan?.Name ?? "Workout";
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Discard workout?",
            $"Remove this in-progress session for '{planName}' and all logged sets? This cannot be undone.",
            confirmText: "Discard",
            cancelText: "Cancel",
            confirmColor: Color.Error);
        if (confirmed)
            await DiscardWorkout();
    }

    private async Task DiscardWorkout()
    {
        if (_disposed) return;

        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();

        if (_historySessionId != null)
        {
            try
            {
                await HistoryRepository.DeleteSessionAsync(_historySessionId);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"History DeleteSession error: {ex}");
            }
        }

        _historySessionId = null;
        SessionService.EndWorkout();
        Navigation.NavigateTo("/");
    }

    private static double GetProgressValue(int completed, int total) =>
        total == 0 ? 0 : (completed * 100.0) / total;

    private void ToggleAccordion(int exerciseIndex)
    {
        _activeExerciseIndex = _activeExerciseIndex == exerciseIndex ? -1 : exerciseIndex;
    }

    private void HandleWeightChanged(int exIdx, int setIdx, object? val)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        if (double.TryParse(val?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var w))
        {
            _setInputs[key] = (w, current.Reps);
        }
        else if (double.TryParse(val?.ToString(), out w))
        {
            _setInputs[key] = (w, current.Reps);
        }
        else
        {
            _setInputs[key] = (null, current.Reps);
        }
    }

    private void HandleRepsChanged(int exIdx, int setIdx, object? val)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        if (int.TryParse(val?.ToString(), out var r))
        {
            _setInputs[key] = (current.Weight, r);
        }
        else
        {
            _setInputs[key] = (current.Weight, null);
        }
    }

    private void HandleWeightStepperChanged(int exIdx, int setIdx, double? val)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        _setInputs[key] = (val, current.Reps);
    }

    private void HandleRepsStepperChanged(int exIdx, int setIdx, double? val)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        _setInputs[key] = (current.Weight, val.HasValue ? (int)Math.Round(val.Value) : null);
    }


    private void HandleFocus(int exIdx, int setIdx, bool isWeight)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        var plan = SessionService.CurrentPlan;
        
        if (plan != null && exIdx >= 0 && exIdx < plan.Exercises.Count)
        {
            var exercise = plan.Exercises[exIdx];
            var lastWeight = current.Weight ?? (_originalValues.TryGetValue(key, out var orig) ? orig.Weight : (exercise.DefaultWeightKg ?? 0.0));
            var lastReps = current.Reps ?? (_originalValues.TryGetValue(key, out orig) ? orig.Reps : (exercise.DefaultReps ?? 10));
            
            _originalValues[key] = (lastWeight, lastReps);
        }

        if (isWeight)
            _setInputs[key] = (null, current.Reps);
        else
            _setInputs[key] = (current.Weight, null);
    }

    private void HandleBlur(int exIdx, int setIdx, bool isWeight)
    {
        var key = (exIdx, setIdx);
        var current = _setInputs.GetValueOrDefault(key, (null, null));
        
        if (_originalValues.TryGetValue(key, out var original))
        {
            if (isWeight && current.Weight == null)
            {
                _setInputs[key] = (original.Weight, current.Reps);
            }
            else if (!isWeight && current.Reps == null)
            {
                _setInputs[key] = (current.Weight, original.Reps);
            }
        }
    }

    private async Task ToggleSetComplete(int exerciseIndex, int setIndex)
    {
        if (_isCompleting) return;
        if (_disposed) return;

        var plan = SessionService.CurrentPlan;
        if (plan == null || exerciseIndex < 0 || exerciseIndex >= plan.Exercises.Count) return;
        var exercise = plan.Exercises[exerciseIndex];

        bool isCompleted = SessionService.IsSetCompleted(exerciseIndex, setIndex);

        if (isCompleted)
        {
            _isCompleting = true;
            await SafeStateHasChangedAsync();
            try
            {
                SessionService.TryRemoveSet(exerciseIndex, setIndex);
                if (_historySessionId != null)
                {
                    await HistoryRepository.DeleteSetLogAsync(_historySessionId, exerciseIndex, setIndex);
                }

                await StopJsTimerAsync();
                RestNotifications.CancelAllRestNotifications();
                _isRestComplete = false;
                SessionService.SkipRest();

                _activeSetIndices[exerciseIndex] = setIndex; // Make uncompleted set active

                Snackbar.Add("Set unlogged.", Severity.Info);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error unlogging set: {ex}");
            }
            finally
            {
                _isCompleting = false;
                await SafeStateHasChangedAsync();
            }
        }
        else
        {
            _isCompleting = true;
            await SafeStateHasChangedAsync();
            try
            {
                await UnlockAudioContextAsync();

                var inputKey = (exerciseIndex, setIndex);
                var inputs = _setInputs.GetValueOrDefault(inputKey, (null, null));

                var origWeight = _originalValues.TryGetValue(inputKey, out var orig) ? orig.Weight : (exercise.DefaultWeightKg ?? 0.0);
                var origReps = _originalValues.TryGetValue(inputKey, out orig) ? orig.Reps : (exercise.DefaultReps ?? 10);
                
                var finalWeight = inputs.Weight ?? origWeight;
                var finalReps = inputs.Reps ?? origReps;

                var willBeLastSetOfWorkout = SessionService.WouldCompleteWorkout(exerciseIndex, setIndex);

                if (willBeLastSetOfWorkout && SessionService.IsResting)
                {
                    RestNotifications.CancelAllRestNotifications();
                    SessionService.SkipRest();
                }

                _isRestComplete = false;
                SessionService.CompleteSet(exerciseIndex, setIndex);

                // Auto active set update
                int firstUncompletedSetIdx = -1;
                for (int s = 0; s < exercise.SetCount; s++)
                {
                    if (!SessionService.IsSetCompleted(exerciseIndex, s))
                    {
                        firstUncompletedSetIdx = s;
                        break;
                    }
                }
                _activeSetIndices[exerciseIndex] = firstUncompletedSetIdx == -1 ? 0 : firstUncompletedSetIdx;

                if (_historySessionId != null)
                {
                    await HistoryRepository.LogSetAsync(_historySessionId, exerciseIndex, exercise.Name, setIndex, finalReps, finalWeight);
                }

                _setInputs[inputKey] = (finalWeight, finalReps);
                _originalValues.Remove(inputKey);

                ShowUndoSetToast();

                if (willBeLastSetOfWorkout)
                {
                    RestNotifications.CancelAllRestNotifications();
                    await SafeStateHasChangedAsync();
                    await OnWorkoutComplete();
                    return;
                }

                _isRestComplete = false;
                await StopJsTimerAsync();
                RestNotifications.CancelAllRestNotifications();
                _lastRestDurationSeconds = exercise.RestIntervalSeconds;
                SessionService.StartRest(exercise.RestIntervalSeconds);
                await StartJsTimerAsync();
                await ScheduleRestNotificationIfRestingAsync();

                // Auto accordion transition
                bool exerciseDone = true;
                for (int s = 0; s < exercise.SetCount; s++)
                {
                    if (!SessionService.IsSetCompleted(exerciseIndex, s))
                    {
                        exerciseDone = false;
                        break;
                    }
                }

                if (exerciseDone)
                {
                    int nextIdx = -1;
                    for (int e = 0; e < plan.Exercises.Count; e++)
                    {
                        bool thisExDone = true;
                        for (int s = 0; s < plan.Exercises[e].SetCount; s++)
                        {
                            if (!SessionService.IsSetCompleted(e, s))
                            {
                                thisExDone = false;
                                break;
                            }
                        }
                        if (!thisExDone)
                        {
                            nextIdx = e;
                            break;
                        }
                    }

                    if (nextIdx != -1)
                    {
                        _activeExerciseIndex = nextIdx;
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error logging set: {ex}");
            }
            finally
            {
                _isCompleting = false;
                await SafeStateHasChangedAsync();
            }
        }
    }

    private void ShowUndoSetToast()
    {
        HideUndoToast();
        _undoSnackbar = Snackbar.Add("Set logged.", Severity.Info, config =>
        {
            config.Action = "Undo";
            config.ActionColor = Color.Warning;
            config.ShowCloseIcon = true;
            config.RequireInteraction = false;
            config.OnClick = snackbar => UndoLastSetCoreAsync();
        });
    }

    private void HideUndoToast()
    {
        if (_undoSnackbar != null)
        {
            Snackbar.Remove(_undoSnackbar);
            _undoSnackbar = null;
        }
    }

    private async Task UndoLastSetCoreAsync()
    {
        if (_disposed || _isCompleting) return;
        if (!SessionService.TryUndoLastSet(out var removed)) return;

        HideUndoToast();
        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();
        _isRestComplete = false;
        SessionService.SkipRest();

        _activeSetIndices[removed.ExerciseIndex] = removed.SetIndex;

        if (_historySessionId != null)
        {
            try
            {
                await HistoryRepository.TryDeleteLastSetLogAsync(_historySessionId);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"History undo set log error: {ex}");
            }
        }

        await SafeStateHasChangedAsync();
    }

    private void SelectActiveSet(int exerciseIndex, int setIndex)
    {
        if (!SessionService.IsSetCompleted(exerciseIndex, setIndex))
        {
            _activeSetIndices[exerciseIndex] = setIndex;
        }
    }

    private async Task PauseRest()
    {
        if (_disposed) return;

        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();
        SessionService.PauseRest();
        await SafeStateHasChangedAsync();
    }

    private async Task ResumeRest()
    {
        if (_disposed) return;

        var expired = SessionService.ResumeRest();
        if (expired)
        {
            _isRestComplete = true;
            await StopJsTimerAsync();
            await SafeStateHasChangedAsync();
            await PlayRestCompleteAlertsAsync();
        }
        else
        {
            await StartJsTimerAsync();
            await ScheduleRestNotificationIfRestingAsync();
            await SafeStateHasChangedAsync();
        }
    }

    private async Task ResetRest()
    {
        if (_disposed) return;

        _isRestComplete = false;
        RestNotifications.CancelAllRestNotifications();

        if (SessionService.IsResting)
            SessionService.ResetRest();
        else if (_lastRestDurationSeconds > 0)
            SessionService.StartRest(_lastRestDurationSeconds);
        else
            return;

        if (SessionService.IsResting)
        {
            await StartJsTimerAsync();
            await ScheduleRestNotificationIfRestingAsync();
        }

        await SafeStateHasChangedAsync();
    }

    private async Task SkipRest()
    {
        if (_disposed) return;

        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();
        _isRestComplete = false;
        SessionService.SkipRest();
        await SafeStateHasChangedAsync();
    }

    private async Task PlayRestCompleteAlertsAsync()
    {
        if (!RestAlertSettings.Enabled)
            return;

        var planName = SessionService.CurrentPlan?.Name ?? "Workout";
        var description = $"{planName}: start your next set when you are ready.";

        try
        {
            RestNotifications.CancelAllRestNotifications();
            await RestNotifications.ShowRestCompleteNowAsync(description);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Rest notification error: {ex}");
        }

        try
        {
            Vibration.Default.Vibrate(TimeSpan.FromMilliseconds(500));
        }
        catch
        {
            // Silently fail if vibration not supported
        }

        try
        {
            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("playRestCompleteSound");
        }
        catch
        {
            // Silently fail if audio not supported
        }
    }

    private async Task UnlockAudioContextAsync()
    {
        try
        {
            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("unlockAudioContext");
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private async Task ScheduleRestNotificationIfRestingAsync()
    {
        if (!RestAlertSettings.Enabled)
            return;

        var ends = SessionService.RestEndsAtUtc;
        if (ends == null) return;

        var title = SessionService.CurrentPlan?.Name ?? "Physiquinator";
        await RestNotifications.ScheduleRestEndAsync(ends.Value, title, "Rest finished — time for your next set.");
    }

    private void OnSessionRestCompletedWhileBackground(object? sender, EventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            if (_disposed) return;

            await StopJsTimerAsync();
            _isRestComplete = true;
            await SafeStateHasChangedAsync();
            await PlayRestCompleteAlertsAsync();
            await SafeStateHasChangedAsync();
        });
    }

    private async Task OnWorkoutComplete()
    {
        try
        {
            Vibration.Default.Vibrate(TimeSpan.FromMilliseconds(800));

            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("playWorkoutCompleteSound");
        }
        catch
        {
            // Silently fail if vibration or audio not supported
        }
    }

    private async Task EndWorkout()
    {
        if (_disposed) return;

        await StopJsTimerAsync();
        RestNotifications.CancelAllRestNotifications();

        try
        {
            await HistoryRepository.EndSessionAsync(_historySessionId);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"History EndSession error: {ex}");
        }

        _historySessionId = null;
        SessionService.EndWorkout();
        Navigation.NavigateTo("/");
    }

    /// <summary>
    /// Called by the JS timer on each tick. Returns <c>true</c> when the rest
    /// period ends, signalling JS to stop rescheduling.
    /// </summary>
    [JSInvokable]
    public async Task<bool> OnTimerTick()
    {
        if (_disposed) return true;

        var done = SessionService.TickRest();
        if (done)
        {
            // TickRest clears IsResting; without this flag first, the timer block unmounts for one frame.
            _isRestComplete = true;
        }

        await SafeStateHasChangedAsync();

        if (done)
        {
            await PlayRestCompleteAlertsAsync();
            return true;
        }

        return false;
    }

    private async Task StartJsTimerAsync()
    {
        if (_disposed) return;

        try
        {
            if (_audioModule != null && _dotNetRef != null)
                await _audioModule.InvokeVoidAsync("startRestTimer", _dotNetRef, 1000);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private async Task StopJsTimerAsync()
    {
        try
        {
            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("stopRestTimer");
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private static string FormatTime(int totalSeconds)
    {
        if (totalSeconds < 60)
        {
            return $"{totalSeconds}";
        }
        var m = totalSeconds / 60;
        var s = totalSeconds % 60;
        return $"{m:D2}:{s:D2}";
    }

    private static string FormatMinutes(int totalSeconds)
    {
        return $"{totalSeconds / 60:D2}";
    }

    private static string FormatSecondsTens(int totalSeconds)
    {
        var s = totalSeconds % 60;
        return $"{s / 10}";
    }

    private static string FormatSecondsUnits(int totalSeconds)
    {
        var s = totalSeconds % 60;
        return $"{s % 10}";
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        HideUndoToast();
        SessionService.RestCompletedWhileBackground -= OnSessionRestCompletedWhileBackground;
        RestNotifications.CancelAllRestNotifications();
        SessionService.CancelRest();
        try
        {
            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("stopRestTimer");
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
        _dotNetRef?.Dispose();
        if (_audioModule != null)
        {
            try
            {
                await _audioModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
    }

    private async Task SafeStateHasChangedAsync()
    {
        if (_disposed) return;

        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private void ToggleCompletedExpanded()
    {
        _completedExpanded = !_completedExpanded;
    }
}
