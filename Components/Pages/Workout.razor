@page "/workout/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject WorkoutSessionService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="mb-3 mt-3">
    <a href="/" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-2"></i>Back to Home
    </a>
</div>

<h1><i class="bi bi-fire me-2"></i>@(SessionService.CurrentPlan?.Name ?? "Workout")</h1>

@if (SessionService.CurrentPlan == null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: #f59e0b; opacity: 0.5;"></i>
        <p class="mt-3">No active workout. <a href="/">Go to home</a> and start a plan.</p>
    </div>
}
else
{
    <div class="workout-timer-section mb-4">
        @if (SessionService.IsResting || _isRestComplete)
        {
            <div class="rest-timer card @(_isRestComplete ? "rest-complete-pulse" : "")">
                <div class="card-body text-center">
                    <p class="mb-2 text-uppercase fw-bold" style="color: @(_isRestComplete ? "#4ade80" : "#f59e0b"); letter-spacing: 2px;">
                        <i class="bi @(_isRestComplete ? "bi-bell-fill" : "bi-hourglass-split") me-2"></i>@(_isRestComplete ? "Rest Complete!" : "Rest Time")
                    </p>
                    <p class="display-4 mb-3" style="color: @(_isRestComplete ? "#4ade80" : "inherit")">@FormatTime(SessionService.RestSecondsRemaining)</p>
                    @if (!_isRestComplete)
                    {
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            @if (SessionService.IsRestPaused)
                            {
                                <button class="btn btn-success" @onclick="ResumeRest">
                                    <i class="bi bi-play-fill me-2"></i>Resume
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-pause" @onclick="PauseRest">
                                    <i class="bi bi-pause-fill me-2"></i>Pause
                                </button>
                            }
                            <button class="btn btn-info" @onclick="ResetRest">
                                <i class="bi bi-arrow-clockwise me-2"></i>Reset
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="SkipRest">
                                <i class="bi bi-skip-forward-fill me-2"></i>Skip
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="row g-4 exercise-layout">
        <div class="col-lg-6 completed-section">
            <div class="d-flex align-items-center mb-3">
                <h2 class="h5 mb-0 text-success">
                    <i class="bi bi-check-circle-fill me-2"></i>Completed
                </h2>
            </div>
            <div class="exercise-panels">
                @foreach (var item in DoneExercises)
                {
                    <div class="card mb-3" @key="item.ExerciseIndex">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-2">
                                        <i class="bi bi-trophy-fill text-success me-2"></i>@item.ExerciseName
                                    </h5>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-3" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: @GetProgressPercentage(item.CompletedSets, item.TotalSets)%"></div>
                                        </div>
                                        <span class="badge bg-success">
                                            @item.CompletedSets/@item.TotalSets
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (!DoneExercises.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-circle" style="font-size: 3rem; color: #667eea; opacity: 0.2;"></i>
                        <p class="text-muted mt-3">Complete a set to see it here.</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6 upcoming-section">
            <div class="d-flex align-items-center mb-3">
                <h2 class="h5 mb-0">
                    <i class="bi bi-lightning-charge-fill me-2" style="color: #667eea;"></i>Up Next
                </h2>
            </div>
            <div class="exercise-panels">
                @foreach (var item in UpcomingExercises)
                {
                    <div class="card mb-3" @key="item.ExerciseIndex">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div class="flex-grow-1 mb-2">
                                    <h5 class="card-title mb-2">
                                        <i class="bi bi-dot me-1" style="color: #667eea; font-size: 1.5rem;"></i>@item.ExerciseName
                                    </h5>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-3" style="height: 8px;">
                                            <div class="progress-bar" style="width: @GetProgressPercentage(item.CompletedSets, item.TotalSets)%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
                                        </div>
                                        <span class="badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                            @item.CompletedSets/@item.TotalSets
                                        </span>
                                    </div>
                                </div>
                                <button class="btn btn-primary w-100" @onclick="async () => await CompleteNextSet(item.ExerciseIndex)" disabled="@_isCompleting">
                                    <i class="bi bi-check2-circle me-2"></i>Complete Set @(item.CompletedSets + 1)
                                </button>
                            </div>
                        </div>
                    </div>
                }
                @if (!UpcomingExercises.Any() && DoneExercises.Any())
                {
                    <div class="text-center py-5 workout-complete-celebration">
                        <i class="bi bi-trophy-fill" style="font-size: 4rem; color: #4ade80;"></i>
                        <h3 class="mt-3" style="color: #4ade80;">Workout Complete!</h3>
                        <p class="text-muted">Great work! All sets completed.</p>
                        <div class="confetti-container"></div>
                    </div>
                }
                @if (!UpcomingExercises.Any() && !DoneExercises.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #667eea; opacity: 0.3;"></i>
                        <p class="text-muted mt-3">No sets in this plan.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-danger" @onclick="EndWorkout">
            <i class="bi bi-stop-circle me-2"></i>End Workout
        </button>
        <a href="/" class="btn btn-link">
            <i class="bi bi-house-fill me-2"></i>Back to Home
        </a>
    </div>
}

@code {
    [Parameter]
    public Guid PlanId { get; set; }

    private bool _isRestComplete;
    private IJSObjectReference? _audioModule;
    private bool _isCompleting;
    private bool _disposed;
    private DotNetObjectReference<Workout>? _dotNetRef;
    private record ExerciseProgress(string ExerciseName, int ExerciseIndex, int CompletedSets, int TotalSets);

    private List<ExerciseProgress> DoneExercises => GetExerciseProgress(completed: true);
    private List<ExerciseProgress> UpcomingExercises => GetExerciseProgress(completed: false);

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        _audioModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/workoutTimer.js");
        var plan = await PlanService.GetPlanAsync(PlanId);
        if (plan != null)
            SessionService.StartWorkout(plan);
    }

    protected override async Task OnParametersSetAsync()
    {
        var plan = await PlanService.GetPlanAsync(PlanId);
        if (plan != null && SessionService.CurrentPlan?.Id != plan.Id)
        {
            SessionService.StartWorkout(plan);
        }
    }

    private List<ExerciseProgress> GetExerciseProgress(bool completed)
    {
        var plan = SessionService.CurrentPlan;
        if (plan == null) return [];

        var completedSetsSet = SessionService.CompletedSets.ToHashSet();
        var list = new List<ExerciseProgress>();

        for (var ei = 0; ei < plan.Exercises.Count; ei++)
        {
            var ex = plan.Exercises[ei];
            var completedSets = 0;

            for (var si = 0; si < ex.SetCount; si++)
            {
                if (completedSetsSet.Contains(new SetCompletion(ei, si)))
                    completedSets++;
            }

            var isFullyCompleted = completedSets == ex.SetCount;
            var hasAnySets = completedSets > 0;

            if (completed)
            {
                if (hasAnySets)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
            else
            {
                if (!isFullyCompleted)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
        }
        return list;
    }

    private async Task CompleteNextSet(int exerciseIndex)
    {
        if (_isCompleting) return;

        var plan = SessionService.CurrentPlan;
        if (plan == null || exerciseIndex < 0 || exerciseIndex >= plan.Exercises.Count) return;

        _isCompleting = true;
        StateHasChanged();

        try
        {
            var exercise = plan.Exercises[exerciseIndex];

            for (var si = 0; si < exercise.SetCount; si++)
            {
                if (!SessionService.IsSetCompleted(exerciseIndex, si))
                {
                    var completedCount = 0;
                    for (var checkSi = 0; checkSi < exercise.SetCount; checkSi++)
                    {
                        if (SessionService.IsSetCompleted(exerciseIndex, checkSi))
                            completedCount++;
                    }

                    var isLastExercise = exerciseIndex == plan.Exercises.Count - 1;
                    var willBeLastSetOfExercise = (completedCount + 1) >= exercise.SetCount;
                    var willBeLastSetOfWorkout = isLastExercise && willBeLastSetOfExercise;

                    if (willBeLastSetOfWorkout && SessionService.IsResting)
                        SessionService.SkipRest();

                    _isRestComplete = false;
                    SessionService.CompleteSet(exerciseIndex, si);

                    if (willBeLastSetOfWorkout)
                    {
                        StateHasChanged();
                        await OnWorkoutComplete();
                    }

                    if (!willBeLastSetOfWorkout)
                    {
                        _isRestComplete = false;
                        await StopJsTimerAsync();
                        SessionService.StartRest(exercise.RestIntervalSeconds);
                        await StartJsTimerAsync();
                    }

                    StateHasChanged();
                    await Task.Delay(300);
                    break;
                }
            }
        }
        finally
        {
            _isCompleting = false;
            StateHasChanged();
        }
    }

    private void PauseRest()
    {
        SessionService.PauseRest();
        StateHasChanged();
    }

    private async Task ResumeRest()
    {
        var expired = SessionService.ResumeRest();
        StateHasChanged();

        if (expired)
        {
            await StopJsTimerAsync();
            _isRestComplete = true;
            StateHasChanged();
            await OnRestComplete();
        }
    }

    private void ResetRest()
    {
        _isRestComplete = false;
        SessionService.ResetRest();
        StateHasChanged();
    }

    private async Task SkipRest()
    {
        await StopJsTimerAsync();
        _isRestComplete = false;
        SessionService.SkipRest();
        StateHasChanged();
    }

    private async Task OnRestComplete()
    {
        try
        {
            Vibration.Default.Vibrate(TimeSpan.FromMilliseconds(500));

            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("playRestCompleteSound");
        }
        catch
        {
            // Silently fail if vibration or audio not supported
        }
    }

    private async Task OnWorkoutComplete()
    {
        try
        {
            Vibration.Default.Vibrate(TimeSpan.FromMilliseconds(800));

            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("playWorkoutCompleteSound");
        }
        catch
        {
            // Silently fail if vibration or audio not supported
        }
    }

    private async Task EndWorkout()
    {
        await StopJsTimerAsync();
        SessionService.EndWorkout();
        Navigation.NavigateTo("/");
    }

    /// <summary>
    /// Called by the JS timer on each tick. Returns <c>true</c> when the rest
    /// period ends, signalling JS to stop rescheduling.
    /// </summary>
    [JSInvokable]
    public async Task<bool> OnTimerTick()
    {
        if (_disposed) return true;

        var done = SessionService.TickRest();
        StateHasChanged();

        if (done)
        {
            _isRestComplete = true;
            StateHasChanged();
            await OnRestComplete();
            return true;
        }

        return false;
    }

    private async Task StartJsTimerAsync()
    {
        if (_audioModule != null && _dotNetRef != null)
            await _audioModule.InvokeVoidAsync("startRestTimer", _dotNetRef, 1000);
    }

    private async Task StopJsTimerAsync()
    {
        try
        {
            if (_audioModule != null)
                await _audioModule.InvokeVoidAsync("stopRestTimer");
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    private static string FormatTime(int totalSeconds)
    {
        var m = totalSeconds / 60;
        var s = totalSeconds % 60;
        return $"{m:D1}:{s:D2}";
    }

    private static string GetProgressPercentage(int completed, int total)
    {
        if (total == 0) return "0";
        var percentage = (completed * 100.0) / total;
        return percentage.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        await StopJsTimerAsync();
        _dotNetRef?.Dispose();
        if (_audioModule != null)
            await _audioModule.DisposeAsync();
    }
}
