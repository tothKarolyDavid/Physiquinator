@page "/workout/{PlanId:guid}"
@inject WorkoutPlanService PlanService
@inject WorkoutSessionService SessionService
@inject NavigationManager Navigation
@implements IDisposable

<h1>@(SessionService.CurrentPlan?.Name ?? "Workout")</h1>

@if (SessionService.CurrentPlan == null)
{
    <p>No active workout. <a href="/">Go to home</a> and start a plan.</p>
}
else
{
    <div class="workout-timer-section mb-4">
        @if (SessionService.IsResting)
        {
            <div class="rest-timer card border-warning">
                <div class="card-body text-center">
                    <p class="mb-1 text-muted">Rest</p>
                    <p class="display-4 mb-2">@FormatTime(SessionService.RestSecondsRemaining)</p>
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        @if (SessionService.IsRestPaused)
                        {
                            <button class="btn btn-success btn-sm" @onclick="ResumeRest">Resume</button>
                        }
                        else
                        {
                            <button class="btn btn-warning btn-sm" @onclick="PauseRest">Pause</button>
                        }
                        <button class="btn btn-info btn-sm" @onclick="ResetRest">Reset</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SkipRest">Skip</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-md-6">
            <h2 class="h5 text-success">Done</h2>
            <div class="exercise-panels">
                @foreach (var item in DoneExercises)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="card-title mb-1">@item.ExerciseName</h5>
                                    <p class="card-text text-success mb-0">
                                        <span class="text-success me-2" aria-hidden="true">✓</span>
                                        @item.CompletedSets/@item.TotalSets sets complete
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (!DoneExercises.Any())
                {
                    <p class="text-muted">Complete a set to see it here.</p>
                }
            </div>
        </div>
        <div class="col-md-6">
            <h2 class="h5">Up next</h2>
            <div class="exercise-panels">
                @foreach (var item in UpcomingExercises)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <h5 class="card-title mb-1">@item.ExerciseName</h5>
                                    <p class="card-text text-muted mb-0">
                                        @item.CompletedSets/@item.TotalSets sets complete
                                    </p>
                                </div>
                                <button class="btn btn-primary btn-sm" @onclick="() => CompleteNextSet(item.ExerciseIndex)">
                                    Complete set @(item.CompletedSets + 1)
                                </button>
                            </div>
                        </div>
                    </div>
                }
                @if (!UpcomingExercises.Any() && DoneExercises.Any())
                {
                    <p class="text-muted">All sets complete. Great work!</p>
                }
                @if (!UpcomingExercises.Any() && !DoneExercises.Any())
                {
                    <p class="text-muted">No sets in this plan.</p>
                }
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button class="btn btn-outline-danger" @onclick="EndWorkout">End workout</button>
        <a href="/" class="btn btn-link">Back to home</a>
    </div>
}

@code {
    [Parameter]
    public Guid PlanId { get; set; }

    private record ExerciseProgress(string ExerciseName, int ExerciseIndex, int CompletedSets, int TotalSets);

    private List<ExerciseProgress> DoneExercises => GetExerciseProgress(completed: true);
    private List<ExerciseProgress> UpcomingExercises => GetExerciseProgress(completed: false);

    protected override void OnInitialized()
    {
        var plan = PlanService.GetPlan(PlanId);
        if (plan != null)
            SessionService.StartWorkout(plan);
    }

    protected override void OnParametersSet()
    {
        var plan = PlanService.GetPlan(PlanId);
        if (plan != null && SessionService.CurrentPlan?.Id != plan.Id)
        {
            SessionService.StartWorkout(plan);
        }
    }

    private List<ExerciseProgress> GetExerciseProgress(bool completed)
    {
        var plan = SessionService.CurrentPlan;
        if (plan == null) return new List<ExerciseProgress>();

        var list = new List<ExerciseProgress>();
        for (var ei = 0; ei < plan.Exercises.Count; ei++)
        {
            var ex = plan.Exercises[ei];
            var completedSets = 0;
            for (var si = 0; si < ex.SetCount; si++)
            {
                if (SessionService.IsSetCompleted(ei, si))
                    completedSets++;
            }

            var isFullyCompleted = completedSets == ex.SetCount;
            var hasAnySets = completedSets > 0;

            if (completed)
            {
                if (hasAnySets)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
            else
            {
                if (!isFullyCompleted)
                    list.Add(new ExerciseProgress(ex.Name, ei, completedSets, ex.SetCount));
            }
        }
        return list;
    }

    private void CompleteNextSet(int exerciseIndex)
    {
        var plan = SessionService.CurrentPlan;
        if (plan == null || exerciseIndex < 0 || exerciseIndex >= plan.Exercises.Count) return;

        var exercise = plan.Exercises[exerciseIndex];

        // Find the next incomplete set
        for (var si = 0; si < exercise.SetCount; si++)
        {
            if (!SessionService.IsSetCompleted(exerciseIndex, si))
            {
                SessionService.CompleteSet(exerciseIndex, si);

                // Start rest timer if not the last set of this exercise
                var completedCount = 0;
                for (var checkSi = 0; checkSi < exercise.SetCount; checkSi++)
                {
                    if (SessionService.IsSetCompleted(exerciseIndex, checkSi))
                        completedCount++;
                }

                if (completedCount < exercise.SetCount)
                {
                    SessionService.StartRest(
                        restIntervalSeconds: exercise.RestIntervalSeconds,
                        onTick: () => InvokeAsync(StateHasChanged),
                        onComplete: () => InvokeAsync(StateHasChanged));
                }

                StateHasChanged();
                break;
            }
        }
    }

    private void PauseRest()
    {
        SessionService.PauseRest();
        StateHasChanged();
    }

    private void ResumeRest()
    {
        SessionService.ResumeRest();
        StateHasChanged();
    }

    private void ResetRest()
    {
        SessionService.ResetRest();
        StateHasChanged();
    }

    private void SkipRest()
    {
        SessionService.SkipRest();
        StateHasChanged();
    }

    private void EndWorkout()
    {
        SessionService.EndWorkout();
        Navigation.NavigateTo("/");
    }

    private static string FormatTime(int totalSeconds)
    {
        var m = totalSeconds / 60;
        var s = totalSeconds % 60;
        return $"{m:D1}:{s:D2}";
    }

    public void Dispose() { }
}
