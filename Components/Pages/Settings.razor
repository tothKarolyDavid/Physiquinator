@page "/settings"
@using Physiquinator.Services
@using Physiquinator.Models
@inject ThemeService ThemeService
@inject RestAlertSettingsService RestAlertSettings
@inject WorkoutPlanService PlanService
@inject WorkoutHistoryService HistoryService
@inject AppDataResetService AppDataReset
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserProfileService UserProfileService
@implements IDisposable

<PageTitle>Settings</PageTitle>

<MudStack Spacing="3">
    <PageHeader Title="Settings" ShowBack="false" />

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Palette" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Appearance</MudText>
        </div>
        <MudSelect T="string"
                   Variant="Variant.Filled"
                   Label="Light or dark mode"
                   Value="_preference"
                   ValueChanged="OnThemePreferenceChanged">
            <MudSelectItem Value="@("system")">Match system</MudSelectItem>
            <MudSelectItem Value="@("light")">Light (always)</MudSelectItem>
            <MudSelectItem Value="@("dark")">Dark (always)</MudSelectItem>
        </MudSelect>
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
            Active mode: <strong>@_effectiveThemeLabel</strong>
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Timer" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Rest timer alerts</MudText>
        </div>
        <MudSwitch T="bool"
                   Label="Notify when rest ends"
                   Value="_restAlertsEnabled"
                   ValueChanged="OnRestAlertsEnabledChanged" />
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
            When off, rest-end notifications, sound, and vibration are disabled during workouts. The on-screen rest timer still runs.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.MonitorWeight" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Bodyweight</MudText>
        </div>
        <MudNumericField T="double?"
                         Label="Bodyweight (kg)"
                         Variant="Variant.Filled"
                         Value="_bodyweight"
                         ValueChanged="OnBodyweightChanged"
                         Min="0"
                         Max="500"
                         Format="0.##"
                         Clearable="true" />
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
            Provide your bodyweight to calculate absolute weight and total volume for bodyweight exercises (optional).
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Backup" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Plans backup</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Export all plans as JSON, or import a file you exported earlier.
        </MudText>
        <div class="settings-btn-group">
            <MudButton Variant="Variant.Outlined"
                       Disabled="@(_planCount == 0)"
                       OnClick="ExportAllPlans"
                       StartIcon="@Icons.Material.Filled.Upload">
                Export all plans
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ImportPlans" StartIcon="@Icons.Material.Filled.Download">
                Import plans
            </MudButton>
        </div>
        @if (_planCount == 0)
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">Create a plan first to enable export.</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.History" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">History backup</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Export or import workout history JSON. Import merges by session and set id.
        </MudText>
        <div class="settings-btn-group">
            <MudButton Variant="Variant.Outlined"
                       Disabled="@(_historySessionCount == 0)"
                       OnClick="ExportHistory"
                       StartIcon="@Icons.Material.Filled.Upload">
                Export history
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ImportHistory" StartIcon="@Icons.Material.Filled.Download">
                Import history
            </MudButton>
        </div>
        @if (_historySessionCount == 0)
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">Finish at least one workout to enable export.</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.People" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">User Profiles</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Create, switch, or manage isolated user profiles. Each profile stores its own plans and history.
        </MudText>

        <MudStack Spacing="2" Class="mb-3">
            @foreach (var profile in _profiles)
            {
                var isActive = profile.Id == _activeProfile.Id;
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-3 rounded-lg"
                          Style='@(isActive ? "background-color: var(--mud-palette-primary-hover); border: 1px solid var(--mud-palette-primary);" : "background-color: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider);")'>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudAvatar Color="@(isActive ? Color.Primary : Color.Default)" Size="Size.Medium">
                            @profile.Name.Substring(0, Math.Min(profile.Name.Length, 2)).ToUpper()
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.body1" Class="fw-semibold">@profile.Name</MudText>
                                @if (isActive)
                                {
                                    <span style="font-size: 0.75rem; background-color: var(--mud-palette-primary); color: white; padding: 2px 8px; border-radius: 4px; font-weight: 600;">Active</span>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                                Created: @profile.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (!isActive)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => SwitchProfileAsync(profile.Id))"
                                           title="Switch Profile"
                                           Style="border-radius: 50%;" />
                        }
                        
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Variant="Variant.Outlined"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="@(() => RenameProfileAsync(profile.Id, profile.Name))"
                                       title="Rename Profile"
                                       Style="border-radius: 50%;" />

                        @if (profile.Id != Guid.Empty)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => DeleteProfileAsync(profile.Id, profile.Name))"
                                           title="Delete Profile"
                                           Style="border-radius: 50%;" />
                        }
                    </MudStack>
                </MudStack>
            }
        </MudStack>

        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="CreateProfileAsync" Style="text-transform: none; border-radius: 12px; font-weight: 600;">
            Add Profile
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card settings-card--danger" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Color="Color.Error" Class="settings-card__title">Remove all data</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Permanently deletes every plan and workout log on this device. Export backups first if needed.
        </MudText>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   OnClick="RemoveAllDataAsync"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   Style="text-transform: none; border-radius: 12px; font-weight: 600;">
            Remove all data…
        </MudButton>
    </MudPaper>
</MudStack>

@code {
    private string _preference = "system";
    private string _effectiveTheme = "dark";
    private bool _restAlertsEnabled = true;
    private int _planCount;
    private int _historySessionCount;
    private List<UserProfile> _profiles = new();
    private UserProfile _activeProfile = null!;
    private double? _bodyweight;

    private string _effectiveThemeLabel => _effectiveTheme == "light" ? "Light" : "Dark";

    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += HandleThemeChanged;
        RestAlertSettings.Changed += HandleRestAlertsChanged;
        SyncFromService();
        await RefreshPlanCountAsync();
        await RefreshHistoryCountAsync();
        _profiles = UserProfileService.GetProfiles();
        _activeProfile = UserProfileService.GetActiveProfile();
        _bodyweight = _activeProfile.BodyweightKg;
    }

    private void OnBodyweightChanged(double? value)
    {
        _bodyweight = value;
        if (_activeProfile != null)
        {
            UserProfileService.UpdateBodyweight(_activeProfile.Id, value);
            _activeProfile.BodyweightKg = value;
        }
    }

    private async Task RefreshPlanCountAsync()
    {
        var plans = await PlanService.GetAllPlansAsync();
        _planCount = plans.Count;
    }

    private async Task RefreshHistoryCountAsync()
    {
        _historySessionCount = await HistoryService.GetSessionCountAsync();
    }

    private void HandleThemeChanged()
    {
        SyncFromService();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SyncFromService()
    {
        _preference = ThemeService.Preference;
        _effectiveTheme = ThemeService.EffectiveTheme;
        _restAlertsEnabled = RestAlertSettings.Enabled;
    }

    private void HandleRestAlertsChanged()
    {
        _restAlertsEnabled = RestAlertSettings.Enabled;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnRestAlertsEnabledChanged(bool enabled)
    {
        await RestAlertSettings.SetEnabledAsync(enabled);
        _restAlertsEnabled = enabled;
    }

    private async Task OnThemePreferenceChanged(string preference)
    {
        await ThemeService.SetPreferenceAsync(preference);
    }

    private async Task ExportAllPlans()
    {
        try
        {
            var json = await PlanService.ExportAllPlansToJsonAsync();
            var fileName = $"physiquinator_plans_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await SaveFile(fileName, json);
            Snackbar.Add("All plans exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportPlans()
    {
        try
        {
            var fileTypesDict = new PlatformFileTypes
            {
                { DevicePlatform.iOS, ["public.json"] },
                { DevicePlatform.Android, ["application/json"] },
                { DevicePlatform.WinUI, [".json"] },
                { DevicePlatform.MacCatalyst, ["public.json"] }
            };
            var result = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = "Select workout plan JSON file",
                FileTypes = new FilePickerFileType(fileTypesDict)
            });

            if (result == null)
                return;

            using var stream = await result.OpenReadAsync();
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var importedCount = 0;
            try
            {
                var plans = await PlanService.ImportPlansFromJsonAsync(json);
                importedCount = plans.Count;
            }
            catch
            {
                await PlanService.ImportPlanFromJsonAsync(json);
                importedCount = 1;
            }

            await RefreshPlanCountAsync();
            Snackbar.Add($"Imported {importedCount} plan(s).", Severity.Success);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportHistory()
    {
        try
        {
            var json = await HistoryService.ExportToJsonAsync();
            var fileName = $"physiquinator_history_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await SaveFile(fileName, json, "Export workout history");
            Snackbar.Add("Workout history exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportHistory()
    {
        try
        {
            var fileTypesDict = new PlatformFileTypes
            {
                { DevicePlatform.iOS, ["public.json"] },
                { DevicePlatform.Android, ["application/json"] },
                { DevicePlatform.WinUI, [".json"] },
                { DevicePlatform.MacCatalyst, ["public.json"] }
            };
            var result = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = "Select workout history JSON file",
                FileTypes = new FilePickerFileType(fileTypesDict)
            });

            if (result == null)
                return;

            using var stream = await result.OpenReadAsync();
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var (sessions, sets) = await HistoryService.ImportFromJsonAsync(json);
            await RefreshHistoryCountAsync();
            Snackbar.Add($"Imported {sessions} workout(s) and {sets} set log(s).", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveAllDataAsync()
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Remove all data?",
            "This cannot be undone. Export any backups you need before continuing.",
            confirmText: "Remove",
            confirmColor: Color.Error);

        if (!confirmed)
            return;

        try
        {
            await AppDataReset.ClearAllLocalDataAsync();
            SyncFromService();
            await RefreshPlanCountAsync();
            await RefreshHistoryCountAsync();
            Snackbar.Add("All local data has been removed.", Severity.Success);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not remove data: {ex.Message}", Severity.Error);
        }
    }

    private static async Task SaveFile(string fileName, string content, string shareTitle = "Export Workout Plan")
    {
        var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllTextAsync(filePath, content);
        await Share.RequestAsync(new ShareFileRequest
        {
            Title = shareTitle,
            File = new ShareFile(filePath)
        });
    }

    private async Task CreateProfileAsync()
    {
        var parameters = new DialogParameters { ["Name"] = "" };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<Shared.ProfileInputDialog>("Create Profile", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is string name)
        {
            UserProfileService.CreateProfile(name);
            _profiles = UserProfileService.GetProfiles();
            Snackbar.Add($"Profile '{name}' created.", Severity.Success);
        }
    }

    private async Task RenameProfileAsync(Guid id, string currentName)
    {
        var parameters = new DialogParameters { ["Name"] = currentName };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<Shared.ProfileInputDialog>("Rename Profile", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is string name)
        {
            UserProfileService.RenameProfile(id, name);
            _profiles = UserProfileService.GetProfiles();
            if (_activeProfile.Id == id)
            {
                _activeProfile.Name = name;
            }
            Snackbar.Add($"Profile renamed to '{name}'.", Severity.Success);
        }
    }

    private async Task DeleteProfileAsync(Guid id, string name)
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Delete profile?",
            $"Are you sure you want to delete profile '{name}'? This will permanently delete its workout history, plans, and database file.",
            confirmText: "Delete",
            confirmColor: Color.Error);

        if (!confirmed) return;

        try
        {
            await UserProfileService.DeleteProfileAsync(id);
            Snackbar.Add($"Profile '{name}' deleted.", Severity.Success);
            Navigation.NavigateTo("/settings", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not delete profile: {ex.Message}", Severity.Error);
        }
    }

    private async Task SwitchProfileAsync(Guid id)
    {
        try
        {
            await UserProfileService.SwitchProfileAsync(id);
            Snackbar.Add("Switched profile.", Severity.Success);
            Navigation.NavigateTo("/settings", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to switch profile: {ex.Message}", Severity.Error);
        }
    }

    private sealed class PlatformFileTypes : Dictionary<DevicePlatform, IEnumerable<string>> { }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
        RestAlertSettings.Changed -= HandleRestAlertsChanged;
    }
}
