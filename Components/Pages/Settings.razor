@page "/settings"
@inject ThemeService ThemeService
@inject RestAlertSettingsService RestAlertSettings
@inject WorkoutPlanService PlanService
@inject WorkoutHistoryService HistoryService
@inject AppDataResetService AppDataReset
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Settings</PageTitle>

<MudStack Spacing="3">
    <PageHeader Title="Settings" ShowBack="false" />

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Palette" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Appearance</MudText>
        </div>
        <MudSelect T="string"
                   Variant="Variant.Filled"
                   Label="Light or dark mode"
                   Value="_preference"
                   ValueChanged="OnThemePreferenceChanged">
            <MudSelectItem Value="@("system")">Match system</MudSelectItem>
            <MudSelectItem Value="@("light")">Light (always)</MudSelectItem>
            <MudSelectItem Value="@("dark")">Dark (always)</MudSelectItem>
        </MudSelect>
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
            Active mode: <strong>@_effectiveThemeLabel</strong>
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Timer" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Rest timer alerts</MudText>
        </div>
        <MudSwitch T="bool"
                   Label="Notify when rest ends"
                   Value="_restAlertsEnabled"
                   ValueChanged="OnRestAlertsEnabledChanged" />
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
            When off, rest-end notifications, sound, and vibration are disabled during workouts. The on-screen rest timer still runs.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.Backup" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">Plans backup</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Export all plans as JSON, or import a file you exported earlier.
        </MudText>
        <div class="settings-btn-group">
            <MudButton Variant="Variant.Outlined"
                       Disabled="@(_planCount == 0)"
                       OnClick="ExportAllPlans"
                       StartIcon="@Icons.Material.Filled.Upload">
                Export all plans
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ImportPlans" StartIcon="@Icons.Material.Filled.Download">
                Import plans
            </MudButton>
        </div>
        @if (_planCount == 0)
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">Create a plan first to enable export.</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 settings-card" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.History" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Class="settings-card__title">History backup</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Export or import workout history JSON. Import merges by session and set id.
        </MudText>
        <div class="settings-btn-group">
            <MudButton Variant="Variant.Outlined"
                       Disabled="@(_historySessionCount == 0)"
                       OnClick="ExportHistory"
                       StartIcon="@Icons.Material.Filled.Upload">
                Export history
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ImportHistory" StartIcon="@Icons.Material.Filled.Download">
                Import history
            </MudButton>
        </div>
        @if (_historySessionCount == 0)
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">Finish at least one workout to enable export.</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 settings-card settings-card--danger" Elevation="0">
        <div class="settings-card__header">
            <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" Class="settings-card__icon" />
            <MudText Typo="Typo.h6" Color="Color.Error" Class="settings-card__title">Remove all data</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Permanently deletes every plan and workout log on this device. Export backups first if needed.
        </MudText>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   OnClick="RemoveAllDataAsync"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   Style="text-transform: none; border-radius: 12px; font-weight: 600;">
            Remove all data…
        </MudButton>
    </MudPaper>
</MudStack>

@code {
    private string _preference = "system";
    private string _effectiveTheme = "dark";
    private bool _restAlertsEnabled = true;
    private int _planCount;
    private int _historySessionCount;

    private string _effectiveThemeLabel => _effectiveTheme == "light" ? "Light" : "Dark";

    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += HandleThemeChanged;
        RestAlertSettings.Changed += HandleRestAlertsChanged;
        SyncFromService();
        await RefreshPlanCountAsync();
        await RefreshHistoryCountAsync();
    }

    private async Task RefreshPlanCountAsync()
    {
        var plans = await PlanService.GetAllPlansAsync();
        _planCount = plans.Count;
    }

    private async Task RefreshHistoryCountAsync()
    {
        _historySessionCount = await HistoryService.GetSessionCountAsync();
    }

    private void HandleThemeChanged()
    {
        SyncFromService();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SyncFromService()
    {
        _preference = ThemeService.Preference;
        _effectiveTheme = ThemeService.EffectiveTheme;
        _restAlertsEnabled = RestAlertSettings.Enabled;
    }

    private void HandleRestAlertsChanged()
    {
        _restAlertsEnabled = RestAlertSettings.Enabled;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnRestAlertsEnabledChanged(bool enabled)
    {
        await RestAlertSettings.SetEnabledAsync(enabled);
        _restAlertsEnabled = enabled;
    }

    private async Task OnThemePreferenceChanged(string preference)
    {
        await ThemeService.SetPreferenceAsync(preference);
    }

    private async Task ExportAllPlans()
    {
        try
        {
            var json = await PlanService.ExportAllPlansToJsonAsync();
            var fileName = $"physiquinator_plans_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await SaveFile(fileName, json);
            Snackbar.Add("All plans exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportPlans()
    {
        try
        {
            var result = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = "Select workout plan JSON file",
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.iOS, new[] { "public.json" } },
                    { DevicePlatform.Android, new[] { "application/json" } },
                    { DevicePlatform.WinUI, new[] { ".json" } },
                    { DevicePlatform.MacCatalyst, new[] { "public.json" } }
                })
            });

            if (result == null)
                return;

            using var stream = await result.OpenReadAsync();
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var importedCount = 0;
            try
            {
                var plans = await PlanService.ImportPlansFromJsonAsync(json);
                importedCount = plans.Count;
            }
            catch
            {
                await PlanService.ImportPlanFromJsonAsync(json);
                importedCount = 1;
            }

            await RefreshPlanCountAsync();
            Snackbar.Add($"Imported {importedCount} plan(s).", Severity.Success);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportHistory()
    {
        try
        {
            var json = await HistoryService.ExportToJsonAsync();
            var fileName = $"physiquinator_history_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await SaveFile(fileName, json, "Export workout history");
            Snackbar.Add("Workout history exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportHistory()
    {
        try
        {
            var result = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = "Select workout history JSON file",
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.iOS, new[] { "public.json" } },
                    { DevicePlatform.Android, new[] { "application/json" } },
                    { DevicePlatform.WinUI, new[] { ".json" } },
                    { DevicePlatform.MacCatalyst, new[] { "public.json" } }
                })
            });

            if (result == null)
                return;

            using var stream = await result.OpenReadAsync();
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var (sessions, sets) = await HistoryService.ImportFromJsonAsync(json);
            await RefreshHistoryCountAsync();
            Snackbar.Add($"Imported {sessions} workout(s) and {sets} set log(s).", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveAllDataAsync()
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Remove all data?",
            "This cannot be undone. Export any backups you need before continuing.",
            confirmText: "Remove",
            confirmColor: Color.Error);

        if (!confirmed)
            return;

        try
        {
            await AppDataReset.ClearAllLocalDataAsync();
            SyncFromService();
            await RefreshPlanCountAsync();
            await RefreshHistoryCountAsync();
            Snackbar.Add("All local data has been removed.", Severity.Success);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not remove data: {ex.Message}", Severity.Error);
        }
    }

    private static async Task SaveFile(string fileName, string content, string shareTitle = "Export Workout Plan")
    {
        var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllTextAsync(filePath, content);
        await Share.RequestAsync(new ShareFileRequest
        {
            Title = shareTitle,
            File = new ShareFile(filePath)
        });
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
        RestAlertSettings.Changed -= HandleRestAlertsChanged;
    }
}
