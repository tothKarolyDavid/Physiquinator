@page "/"
@inject WorkoutPlanService PlanService
@inject NavigationManager Navigation
@inject DemoDataSeeder DemoSeeder

<div class="text-center mb-3 mt-5">
    <h1><i class="bi bi-lightning-charge-fill"></i> Physiquinator</h1>
</div>

<div class="mb-4 text-center">
    <div class="d-flex gap-2 justify-content-center flex-wrap">
        <a href="/plan" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle-fill me-2"></i>New Workout Plan
        </a>
        @if (_plans != null && _plans.Any())
        {
            <button class="btn btn-outline-success btn-lg" @onclick="ExportAllPlans">
                <i class="bi bi-download me-2"></i>Export All
            </button>
        }
        <button class="btn btn-outline-info btn-lg" @onclick="ImportPlans">
            <i class="bi bi-upload me-2"></i>Import Plans
        </button>
    </div>
</div>

<h2 class="h4 mt-5 mb-3"><i class="bi bi-folder-fill me-2"></i>Your Plans</h2>
@if (_plans == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!_plans.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size: 4rem; color: #667eea; opacity: 0.3;"></i>
        <p class="text-muted mt-3">No plans yet. Create one to get started.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var plan in _plans.OrderByDescending(p => p.CreatedAt))
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-2">
                            <i class="bi bi-clipboard-check me-2"></i>@plan.Name
                        </h5>
                        <p class="card-text text-muted mb-3">
                            <i class="bi bi-list-ul me-1"></i>@plan.Exercises.Count exercise(s)
                        </p>
                        <div class="mt-auto d-flex gap-2">
                            <a href="/plan/@plan.Id" class="btn btn-outline-secondary btn-sm flex-fill">
                                <i class="bi bi-pencil-fill me-1"></i>Edit
                            </a>
                            <a href="/workout/@plan.Id" class="btn btn-success btn-sm flex-fill">
                                <i class="bi bi-play-fill me-1"></i>Start
                            </a>
                            <button class="btn btn-outline-info btn-sm" @onclick="() => ExportSinglePlan(plan.Id, plan.Name)" title="Export">
                                <i class="bi bi-download"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeletePlan(plan.Id, plan.Name)">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<WorkoutPlan>? _plans;

    protected override async Task OnInitializedAsync()
    {
        // Seed demo data if this is the first launch
        await DemoSeeder.SeedDemoDataIfNeededAsync();

        _plans = await PlanService.GetAllPlansAsync();
    }

    private async Task DeletePlan(Guid planId, string planName)
    {
        var confirmed = await Application.Current!.MainPage!.DisplayAlert(
            "Delete Plan",
            $"Are you sure you want to delete '{planName}'? This action cannot be undone.",
            "Delete", "Cancel");

        if (confirmed)
        {
            await PlanService.DeletePlanAsync(planId);
            _plans = await PlanService.GetAllPlansAsync();
            StateHasChanged();
        }
    }

    private async Task ExportAllPlans()
    {
        try
        {
            var json = await PlanService.ExportAllPlansToJsonAsync();
            var fileName = $"physiquinator_plans_{DateTime.Now:yyyyMMdd_HHmmss}.json";

            await SaveFile(fileName, json);
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", "All plans exported successfully!", "OK");
        }
        catch (Exception ex)
        {
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"Export failed: {ex.Message}", "OK");
        }
    }

    private async Task ExportSinglePlan(Guid planId, string planName)
    {
        try
        {
            var json = await PlanService.ExportPlanToJsonAsync(planId);
            var safeFileName = string.Join("_", planName.Split(Path.GetInvalidFileNameChars()));
            var fileName = $"{safeFileName}_{DateTime.Now:yyyyMMdd_HHmmss}.json";

            await SaveFile(fileName, json);
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"'{planName}' exported successfully!", "OK");
        }
        catch (Exception ex)
        {
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"Export failed: {ex.Message}", "OK");
        }
    }

    private async Task ImportPlans()
    {
        try
        {
            var result = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = "Select workout plan JSON file",
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.iOS, new[] { "public.json" } },
                    { DevicePlatform.Android, new[] { "application/json" } },
                    { DevicePlatform.WinUI, new[] { ".json" } },
                    { DevicePlatform.MacCatalyst, new[] { "public.json" } }
                })
            });

            if (result != null)
            {
                using var stream = await result.OpenReadAsync();
                using var reader = new StreamReader(stream);
                var json = await reader.ReadToEndAsync();

                var importedCount = 0;
                try
                {
                    var plans = await PlanService.ImportPlansFromJsonAsync(json);
                    importedCount = plans.Count;
                }
                catch
                {
                    var plan = await PlanService.ImportPlanFromJsonAsync(json);
                    importedCount = 1;
                }

                _plans = await PlanService.GetAllPlansAsync();
                StateHasChanged();
                await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"Successfully imported {importedCount} plan(s)!", "OK");
            }
        }
        catch (Exception ex)
        {
            await Application.Current!.MainPage!.DisplayAlert("Physiquinator", $"Import failed: {ex.Message}", "OK");
        }
    }

    private async Task SaveFile(string fileName, string content)
    {
        var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllTextAsync(filePath, content);

        await Share.RequestAsync(new ShareFileRequest
        {
            Title = "Export Workout Plan",
            File = new ShareFile(filePath)
        });
    }
}
