@page "/"
@using Physiquinator.Formatting
@using Physiquinator.Services
@implements IAsyncDisposable
@inject WorkoutPlanService PlanService
@inject WorkoutHistoryRepository HistoryRepository
@inject WorkoutSessionService SessionService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserProfileService UserProfileService
@inject IDemoSeedPreferences DemoSeedPreferences
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<MudStack Spacing="3" Class="home-page">
    <header class="home-header">
        <MudText Typo="Typo.h4" Class="home-header__title">Physiquinator</MudText>
    </header>

    @if (_isLoading)
    {
        <LoadingCenter Label="Loading…" />
    }
    else
    {
    @if (_inProgressSession != null && _inProgressPlanId is { } heroPlanId)
    {
        <MudPaper Class="home-hero" Elevation="0">
            <MudStack Spacing="2">
                <div class="home-hero__header">
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="home-hero__label">
                        In progress
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Class="home-hero__discard"
                                   aria-label="Discard workout"
                                   OnClick="DeleteInProgressWorkoutAsync" />
                </div>
                <MudText Typo="Typo.h6">@_inProgressSession.PlanName</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="home-hero__continue"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="@(() => Navigation.NavigateTo($"/workout/{heroPlanId}"))">
                    Continue workout
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_summary != null)
    {
        <section class="home-stats-section" aria-label="Quick stats">
            <div class="home-stats">
                <MudPaper Class="home-stat" Elevation="0">
                    <MudText Class="home-stat__value">@_summary.CurrentStreakWorkoutDays</MudText>
                    <MudText Class="home-stat__label">Streak</MudText>
                </MudPaper>
                <MudPaper Class="home-stat" Elevation="0">
                    <MudText Class="home-stat__value">@_summary.ThisWeekSessionCount</MudText>
                    <MudText Class="home-stat__label">This week</MudText>
                </MudPaper>
                <MudPaper Class="home-stat" Elevation="0">
                    <MudText Class="home-stat__value home-stat__value--date">@LastSessionLabel</MudText>
                    <MudText Class="home-stat__label">Last workout</MudText>
                </MudPaper>
            </div>
        </section>
    }

    <section aria-label="Your plans">
        <div class="home-plans-header">
            <MudText Typo="Typo.h6">Your plans</MudText>
            @if (_plans != null && _plans.Count > 0)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_plans.Count</MudChip>
            }
        </div>

        @if (_plans == null || !_plans.Any())
        {
            <EmptyState Message="No plans yet. Tap New plan below to create your first workout plan."
                        Icon="@Icons.Material.Outlined.FitnessCenter">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/plan">Create plan</MudButton>
            </EmptyState>
        }
        else
        {
            <div id="home-plan-sortable-list" class="home-plan-list">
                @foreach (var plan in _plans.OrderBy(p => p.SortOrder).ThenByDescending(p => p.CreatedAt))
                {
                    <PlanCard PlanName="@plan.Name"
                              ExerciseCount="@plan.Exercises.Count"
                              OnStart="@(() => StartWorkoutAsync(plan.Id, plan.Name))"
                              OnEdit="@(() => Navigation.NavigateTo($"/plan/{plan.Id}"))"
                              OnExport="@(() => ExportSinglePlan(plan.Id, plan.Name))"
                              OnDelete="@(() => DeletePlan(plan.Id, plan.Name))" />
                }
            </div>
        }
    </section>
    }
</MudStack>

@code {
    private const int HomeStatsWeeks = 12;

    private List<WorkoutPlan>? _plans;
    private WorkoutSessionLogEntity? _inProgressSession;
    private Guid? _inProgressPlanId;
    private WorkoutDaySummary? _summary;
    private WorkoutSessionLogEntity? _lastSession;
    private bool _isLoading = true;
    private DotNetObjectReference<Home>? _dotNetRef;
    private int _lastSortableCount = -1;
    private bool _sortableReady;

    private string LastSessionLabel =>
        _lastSession == null
            ? "—"
            : UiDateFormats.LocalDateCompact(_lastSession.StartedAtUtc);

    protected override async Task OnInitializedAsync()
    {
        var endLocal = DateOnly.FromDateTime(DateTime.Today);
        var (utcStart, utcEndExclusive) = ActivityHeatmap.GetHeatmapQueryUtcBounds(endLocal, HomeStatsWeeks);
        var gridStart = ActivityHeatmap.GetMondayOfWeek(endLocal).AddDays(-7 * (HomeStatsWeeks - 1));

        var plansTask = PlanService.GetAllPlansAsync();
        var activityTask = HistoryRepository.GetSessionCountsByLocalDayAsync(utcStart, utcEndExclusive);
        var recentTask = HistoryRepository.GetRecentSessionsAsync(1);
        var inProgressTask = HistoryRepository.GetAnyInProgressSessionAsync();

        await Task.WhenAll(plansTask, activityTask, recentTask, inProgressTask);

        _plans = await plansTask;
        var activityByDay = await activityTask;
        _summary = WorkoutDayStats.Compute(activityByDay, endLocal, gridStart);
        var recent = await recentTask;
        _lastSession = recent.FirstOrDefault();
        _inProgressSession = await inProgressTask;
        _inProgressPlanId = _inProgressSession != null && Guid.TryParse(_inProgressSession.WorkoutPlanId, out var g)
            ? g
            : null;
        _isLoading = false;
    }

    private async Task StartWorkoutAsync(Guid planId, string planName)
    {
        var open = await HistoryRepository.GetInProgressSessionForPlanAsync(planId);
        if (open != null)
        {
            var continueExisting = await ConfirmDialogService.ConfirmAsync(
                DialogService,
                "Workout in progress",
                $"You have an unfinished session for '{planName}'.",
                confirmText: "Continue",
                confirmColor: Color.Primary,
                cancelText: "Start new");

            if (continueExisting)
            {
                Navigation.NavigateTo($"/workout/{planId}");
                return;
            }

            await HistoryRepository.EndSessionAsync(open.Id);
            await RefreshInProgressAsync();
            Navigation.NavigateTo($"/workout/{planId}?forceNew=true");
            return;
        }

        var anyOpen = await HistoryRepository.GetAnyInProgressSessionAsync();
        if (anyOpen != null && Guid.TryParse(anyOpen.WorkoutPlanId, out var otherPlanId) && otherPlanId != planId)
        {
            var continueOther = await ConfirmDialogService.ConfirmAsync(
                DialogService,
                "Another workout in progress",
                $"You have an unfinished session for '{anyOpen.PlanName}'. Continue that workout?",
                confirmText: "Continue",
                confirmColor: Color.Primary,
                cancelText: "Start new");

            if (continueOther)
            {
                Navigation.NavigateTo($"/workout/{otherPlanId}");
                return;
            }

            await HistoryRepository.EndSessionAsync(anyOpen.Id);
            await RefreshInProgressAsync();
        }

        Navigation.NavigateTo($"/workout/{planId}");
    }

    private async Task RefreshInProgressAsync()
    {
        _inProgressSession = await HistoryRepository.GetAnyInProgressSessionAsync();
        _inProgressPlanId = _inProgressSession != null && Guid.TryParse(_inProgressSession.WorkoutPlanId, out var g)
            ? g
            : null;
    }

    private async Task DeleteInProgressWorkoutAsync()
    {
        if (_inProgressSession == null) return;

        var planName = _inProgressSession.PlanName;
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Discard workout",
            $"Remove the in-progress session for '{planName}' and all logged sets? This cannot be undone.",
            confirmText: "Discard",
            cancelText: "Cancel",
            confirmColor: Color.Error);

        if (!confirmed) return;

        await HistoryRepository.DeleteSessionAsync(_inProgressSession.Id);
        SessionService.EndWorkout();
        await RefreshInProgressAsync();
        Snackbar.Add("Workout discarded.", Severity.Success);
    }

    private async Task DeletePlan(Guid planId, string planName)
    {
        var confirmed = await ConfirmDialogService.ConfirmAsync(
            DialogService,
            "Delete plan",
            $"Delete '{planName}'? This cannot be undone.",
            confirmText: "Delete",
            confirmColor: Color.Error);

        if (!confirmed)
            return;

        await PlanService.DeletePlanAsync(planId);
        _plans = await PlanService.GetAllPlansAsync();
        Snackbar.Add("Plan deleted.", Severity.Success);
    }

    private async Task ExportSinglePlan(Guid planId, string planName)
    {
        try
        {
            var json = await PlanService.ExportPlanToJsonAsync(planId);
            var safeFileName = string.Join("_", planName.Split(Path.GetInvalidFileNameChars()));
            var fileName = $"{safeFileName}_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await SaveFile(fileName, json);
            Snackbar.Add($"'{planName}' exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private static async Task SaveFile(string fileName, string content)
    {
        var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllTextAsync(filePath, content);
        await Share.RequestAsync(new ShareFileRequest
        {
            Title = "Export Workout Plan",
            File = new ShareFile(filePath)
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var showModal = DemoSeedPreferences.Get(UserProfileService.ShowFirstTimeSeedModalKey, false);
            if (showModal)
            {
                // Reset the flag immediately to prevent double opens
                DemoSeedPreferences.Set(UserProfileService.ShowFirstTimeSeedModalKey, false);

                var options = new DialogOptions { CloseOnEscapeKey = false, CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
                await DialogService.ShowAsync<Shared.DemoSeededOnboardingDialog>("Welcome", options);
            }
        }

        if (_plans == null || _plans.Count <= 1)
        {
            if (_lastSortableCount > 0)
            {
                await DestroySortableAsync();
                _lastSortableCount = 0;
                _sortableReady = false;
            }
            return;
        }

        var needsInit = !_sortableReady || _lastSortableCount != _plans.Count || firstRender;
        if (needsInit)
        {
            var ready = await InitSortableAsync();
            if (ready)
            {
                _sortableReady = true;
                _lastSortableCount = _plans.Count;
            }
        }
    }

    private async ValueTask<bool> InitSortableAsync()
    {
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await DestroySortableAsync();
            return await JS.InvokeAsync<bool>("homePlansReorder.init", "home-plan-sortable-list", _dotNetRef);
        }
        catch (JSException)
        {
            return false;
        }
    }

    private async ValueTask DestroySortableAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("homePlansReorder.destroy");
        }
        catch (JSException)
        {
            // Scripts not ready yet
        }
    }

    [JSInvokable]
    public async Task OnPlanReordered(int oldIndex, int newIndex)
    {
        if (_plans == null || oldIndex < 0 || newIndex < 0 || oldIndex >= _plans.Count || newIndex >= _plans.Count)
            return;

        if (oldIndex == newIndex)
            return;

        // Perform local reordering
        var sortedPlans = _plans.OrderBy(p => p.SortOrder).ThenByDescending(p => p.CreatedAt).ToList();
        var itemToMove = sortedPlans[oldIndex];
        sortedPlans.RemoveAt(oldIndex);
        sortedPlans.Insert(newIndex, itemToMove);

        // Update SortOrder on all plans
        for (int i = 0; i < sortedPlans.Count; i++)
        {
            sortedPlans[i].SortOrder = i;
            await PlanService.SavePlanAsync(sortedPlans[i]);
        }

        // Reload plans from DB to make sure they are in sync
        _plans = await PlanService.GetAllPlansAsync();

        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await DestroySortableAsync();
        }
        catch (JSDisconnectedException)
        {
            // WebView disposed
        }

        _dotNetRef?.Dispose();
    }
}
