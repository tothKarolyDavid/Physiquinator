<MudDialog>
    <DialogContent>
        <MudTextField T="string" Label="Profile Name" Value="@Name" ValueChanged="OnNameChanged" Required="true" Immediate="true" AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm" Disabled="@string.IsNullOrWhiteSpace(Name)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Name { get; set; } = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private void Confirm() => MudDialog.Close(DialogResult.Ok(Name));

    private void OnNameChanged(string value)
    {
        Name = value;
    }
}
