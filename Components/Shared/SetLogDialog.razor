<MudDialog Class="set-log-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Log set</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="set-log-dialog__body">
            <SetMetricStepper Label="Reps"
                              @bind-Value="RepsStepperValue"
                              Step="1"
                              IsInteger="true"
                              Format="0"
                              InputMode="numeric" />
            <SetMetricStepper Label="Weight (kg)"
                              @bind-Value="_weightKg"
                              Step="2.5"
                              Format="0.#"
                              InputMode="decimal" />

            <div class="set-log-dialog__footer">
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           OnClick="Confirm"
                           Disabled="@ConfirmDisabled">
                    Log set
                </MudButton>
                <MudButton Variant="Variant.Text"
                           FullWidth="true"
                           OnClick="Cancel">
                    Cancel
                </MudButton>
            </div>
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? InitialReps { get; set; }

    [Parameter]
    public double? InitialWeightKg { get; set; }

    [Parameter]
    public bool ConfirmDisabled { get; set; }

    private int? _reps;
    private double? _weightKg;

    private double? RepsStepperValue
    {
        get => _reps;
        set => _reps = value.HasValue
            ? (int?)Math.Clamp((int)Math.Round(value.Value), 0, int.MaxValue)
            : null;
    }

    protected override void OnInitialized()
    {
        _reps = InitialReps;
        _weightKg = InitialWeightKg;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm() => MudDialog.Close(DialogResult.Ok((_reps, _weightKg)));
}