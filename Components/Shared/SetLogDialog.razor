<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Log set</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudNumericField @bind-Value="_reps" Label="Reps" Min="0" HideSpinButtons="true" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_weightKg" Label="Weight (kg)" Min="0" HideSpinButtons="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm" Disabled="@ConfirmDisabled">
            Complete set
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? InitialReps { get; set; }

    [Parameter]
    public double? InitialWeightKg { get; set; }

    [Parameter]
    public bool ConfirmDisabled { get; set; }

    private int? _reps;
    private double? _weightKg;

    protected override void OnInitialized()
    {
        _reps = InitialReps;
        _weightKg = InitialWeightKg;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm() => MudDialog.Close(DialogResult.Ok((_reps, _weightKg)));
}
