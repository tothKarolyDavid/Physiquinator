@inject IJSRuntime JSRuntime
@implements IDisposable

@if (Compact)
{
    <div class="set-metric-stepper__row set-metric-stepper__row--compact">
        <button type="button"
                class="set-metric-stepper__btn set-metric-stepper__btn--dec set-metric-stepper__btn--compact"
                @onclick="@(() => Adjust(-1))"
                aria-label="@($"Decrease {Label}")">
            -
        </button>
        @if (_editing)
        {
            <input @ref="_inputRef"
                   class="set-metric-stepper__input set-metric-stepper__input--compact"
                   type="number"
                   inputmode="@InputMode"
                   min="@Min.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   step="@Step.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   placeholder="@PlaceholderText"
                   @bind="EditText"
                   @bind:event="oninput"
                   @onblur="CommitEdit"
                   @onkeydown="OnEditKeyDown"
                   onfocus="this.select()"
                   autofocus />
        }
        else
        {
            <button @ref="_valueButtonRef"
                    type="button"
                    class="set-metric-stepper__value set-metric-stepper__value--compact"
                    aria-label="@($"Edit {Label}")"
                    @onclick="StartEdit"
                    data-value="@(Value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0")"
                    data-step="@Step.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                    data-min="@Min.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                    data-is-integer="@IsInteger.ToString().ToLowerInvariant()">
                <span class="set-metric-stepper__drag-hint">⬌</span>
                @DisplayText
            </button>
        }
        <button type="button"
                class="set-metric-stepper__btn set-metric-stepper__btn--inc set-metric-stepper__btn--compact"
                @onclick="@(() => Adjust(1))"
                aria-label="@($"Increase {Label}")">
            +
        </button>
    </div>
}
else
{
    <MudStack Class="set-metric-stepper" Spacing="1">
        <MudText Typo="Typo.caption" Class="set-metric-stepper__label">@Label</MudText>
        <div class="set-metric-stepper__row">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="set-metric-stepper__btn set-metric-stepper__btn--dec"
                       OnClick="@(() => Adjust(-1))"
                       aria-label="@($"Decrease {Label}")">
                -
            </MudButton>
            @if (_editing)
            {
                <input @ref="_inputRef"
                       class="set-metric-stepper__input"
                       type="number"
                       inputmode="@InputMode"
                       min="@Min.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       step="@Step.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       placeholder="@PlaceholderText"
                       @bind="EditText"
                       @bind:event="oninput"
                       @onblur="CommitEdit"
                       @onkeydown="OnEditKeyDown"
                       onfocus="this.select()"
                       autofocus />
            }
            else
            {
                <button @ref="_valueButtonRef"
                        type="button"
                        class="set-metric-stepper__value"
                        aria-label="@($"Edit {Label}")"
                        @onclick="StartEdit"
                        data-value="@(Value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0")"
                        data-step="@Step.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        data-min="@Min.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        data-is-integer="@IsInteger.ToString().ToLowerInvariant()">
                    <span class="set-metric-stepper__drag-hint">⬌</span>
                    @DisplayText
                </button>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="set-metric-stepper__btn set-metric-stepper__btn--inc"
                       OnClick="@(() => Adjust(1))"
                       aria-label="@($"Increase {Label}")">
                +
            </MudButton>
        </div>
    </MudStack>
}

@code {
    [Parameter]
    public string Label { get; set; } = "";

    [Parameter]
    public double? Value { get; set; }

    [Parameter]
    public EventCallback<double?> ValueChanged { get; set; }

    [Parameter]
    public double Step { get; set; } = 1;

    [Parameter]
    public double Min { get; set; }

    [Parameter]
    public bool IsInteger { get; set; }

    [Parameter]
    public string Format { get; set; } = "0";

    [Parameter]
    public string InputMode { get; set; } = "decimal";

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public double? Placeholder { get; set; }

    private bool _editing;
    private string _editText = "";
    private ElementReference _inputRef;
    private ElementReference _valueButtonRef;
    private DotNetObjectReference<SetMetricStepper>? _selfRef;
    private bool _shouldFocusInput;
    private bool _hasTyped;

    private string EditText
    {
        get => _editText;
        set
        {
            _editText = value;
            _hasTyped = true;
        }
    }

    private string DisplayText
    {
        get
        {
            if (!Value.HasValue)
                return "0";

            return IsInteger
                ? ((int)Math.Round(Value.Value)).ToString(Format, System.Globalization.CultureInfo.InvariantCulture)
                : Value.Value.ToString(Format, System.Globalization.CultureInfo.InvariantCulture);
        }
    }

    private string PlaceholderText
    {
        get
        {
            var pVal = Placeholder ?? (Value ?? 0);
            return IsInteger
                ? ((int)Math.Round(pVal)).ToString(System.Globalization.CultureInfo.InvariantCulture)
                : pVal.ToString(Format, System.Globalization.CultureInfo.InvariantCulture);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusInput)
        {
            _shouldFocusInput = false;
            try
            {
                await _inputRef.FocusAsync();
            }
            catch
            {
                // ignore
            }
        }

        if (!_editing && _valueButtonRef.Context != null)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JSRuntime.InvokeVoidAsync("physiquinatorStepper.init", _valueButtonRef, _selfRef);
            }
            catch
            {
                // ignore
            }
        }
    }

    private async Task Adjust(int direction)
    {
        var current = Value ?? 0;
        var next = current + (direction * Step);
        if (next < Min)
            next = Min;

        next = NormalizeValue(next);
        await SetValueAsync(next);
    }

    private void StartEdit()
    {
        _editText = Value.HasValue ? Value.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "";
        _hasTyped = false;
        _editing = true;
        _shouldFocusInput = true;
    }

    private async Task CommitEdit()
    {
        if (!_editing)
            return;

        _editing = false;
        if (!_hasTyped)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editText))
        {
            await SetValueAsync(null);
            return;
        }

        if (!double.TryParse(_editText, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && !double.TryParse(_editText, out parsed))
        {
            return;
        }

        if (parsed < Min)
            parsed = Min;

        await SetValueAsync(NormalizeValue(parsed));
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter")
            await CommitEdit();
        else if (e.Key is "Escape")
            _editing = false;
    }

    private double NormalizeValue(double value)
    {
        if (IsInteger)
            return Math.Round(value);

        return Math.Round(value * 10) / 10;
    }

    private async Task SetValueAsync(double? value)
    {
        if (value.HasValue)
            value = NormalizeValue(value.Value);

        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    [JSInvokable]
    public async Task UpdateValueFromDrag(double newValue)
    {
        await SetValueAsync(newValue);
        StateHasChanged();
    }

    public void Dispose()
    {
        _selfRef?.Dispose();
    }
}