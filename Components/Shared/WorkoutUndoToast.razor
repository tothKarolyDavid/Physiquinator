@inject WorkoutUndoOverlayService Overlay
@implements IDisposable

@if (Overlay.IsVisible)
{
    <div class="workout-undo-toast" role="status" aria-live="polite" aria-label="Undo set">
        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   Class="workout-undo-toast__action"
                   OnClick="UndoClickAsync">
            Undo set
        </MudButton>
    </div>
}

@code {
    protected override void OnInitialized() => Overlay.StateChanged += OnOverlayStateChanged;

    private void OnOverlayStateChanged() => _ = InvokeAsync(StateHasChanged);

    private Task UndoClickAsync() => Overlay.TriggerUndoAsync();

    public void Dispose() => Overlay.StateChanged -= OnOverlayStateChanged;
}