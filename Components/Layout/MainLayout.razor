@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.Extensions.Logging
@using Physiquinator.Services
@inject ThemeService ThemeService
@inject NavigationManager Navigation
@inject ILogger<MainLayout> Logger

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    <main class="app-main-scroll">
        <MudContainer MaxWidth="MaxWidth.Small" Class="pb-4 app-page-container">
            @Body
        </MudContainer>
    </main>

    @if (_showBottomNav)
    {
        <nav class="app-tab-bar" aria-label="Main navigation">
            <div class="app-tab-bar__inner">
                <NavLink href="/" class="app-tab" Match="NavLinkMatch.All" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Medium" />
                    <span class="app-tab__label">Home</span>
                </NavLink>
                <NavLink href="/history" class="app-tab" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Medium" />
                    <span class="app-tab__label">History</span>
                </NavLink>
                <NavLink href="/plan" class="app-tab app-tab--create" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                    <span class="app-tab__label">New plan</span>
                </NavLink>
                <NavLink href="/settings" class="app-tab" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                    <span class="app-tab__label">Settings</span>
                </NavLink>
            </div>
        </nav>
    }
</div>

@code {
    private readonly MudTheme _theme = new();
    private bool _isDark = true;
    private bool _showBottomNav = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await ThemeService.EnsureInitializedAsync();
                SyncThemeFromService();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Theme initialization failed");
            }
        }
        UpdateNavigationState();
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        Navigation.LocationChanged += OnLocationChanged;
        SyncThemeFromService();
        UpdateNavigationState();
    }

    private void OnThemeChanged()
    {
        SyncThemeFromService();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateNavigationState();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SyncThemeFromService() => _isDark = ThemeService.EffectiveTheme == "dark";

    private void UpdateNavigationState()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        _showBottomNav = ShouldShowBottomNav(path);
    }

    private static bool ShouldShowBottomNav(string path)
    {
        if (path.StartsWith("workout/", StringComparison.Ordinal)) return false;
        if (path == "plan" || path.StartsWith("plan/", StringComparison.Ordinal)) return false;
        if (path.StartsWith("history/", StringComparison.Ordinal)) return false;
        return true;
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
