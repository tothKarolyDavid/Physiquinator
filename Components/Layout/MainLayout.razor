@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.Extensions.Logging
@using Physiquinator.Services
@inject ThemeService ThemeService
@inject AppInitializationService AppInit
@inject NavigationManager Navigation
@inject ILogger<MainLayout> Logger

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell @(_showBottomNav ? null : "app-shell--immersive") @(_useFixedDockPadding ? "app-shell--fixed-dock" : null)">
    @if (AppInit.IsReady)
    {
        <main class="app-main-scroll">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pb-4 app-page-container">
                @Body
            </MudContainer>
        </main>
    }

    @if (AppInit.ShowSetupOverlay)
    {
        <div class="app-startup-overlay" aria-busy="true" aria-live="polite">
            <LoadingCenter Label="@(AppInit.SetupStatusMessage ?? "Setting up…")" />
        </div>
    }

    @if (_showBottomNav)
    {
        <nav class="app-tab-bar" aria-label="Main navigation">
            <div class="app-tab-bar__inner app-bottom-dock">
                <NavLink href="/" class="app-tab" Match="NavLinkMatch.All" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Medium" />
                    <span class="app-tab__label">Home</span>
                </NavLink>
                <NavLink href="/history" class="app-tab" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Medium" />
                    <span class="app-tab__label">History</span>
                </NavLink>
                <NavLink href="/plan" class="app-tab app-tab--create" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                    <span class="app-tab__label">New plan</span>
                </NavLink>
                <NavLink href="/settings" class="app-tab" Match="NavLinkMatch.Prefix" ActiveClass="app-tab--active">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                    <span class="app-tab__label">Settings</span>
                </NavLink>
            </div>
        </nav>
    }
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#0F766E", // Deep Teal
            Secondary = "#2563EB", // Active Cobalt
            Tertiary = "#D946EF",
            Success = "#10B981",
            Info = "#06B6D4",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Background = "#F8F9FA",
            Surface = "#FFFFFF",
            AppbarBackground = "#F8F9FA",
            TextPrimary = "#111827",
            TextSecondary = "#6B7280",
            LinesDefault = "rgba(0, 0, 0, 0.08)",
            Divider = "rgba(0, 0, 0, 0.06)",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#10B981", // Active Volt Green (Sporty)
            Secondary = "#3B82F6", // Cobalt Blue
            Tertiary = "#FF006E", // Energy Magenta
            Success = "#10B981",
            Info = "#06B6D4",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Background = "#0B0C10", // Deep Midnight/Obsidian
            Surface = "#151821", // Sleek charcoal card surface
            AppbarBackground = "#0B0C10",
            TextPrimary = "#F3F4F6",
            TextSecondary = "#9CA3AF",
            LinesDefault = "rgba(255, 255, 255, 0.08)",
            Divider = "rgba(255, 255, 255, 0.06)",
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "16px"
        }
    };
    private bool _isDark = true;
    private bool _showBottomNav = true;
    private bool _useFixedDockPadding;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AppInit.EnsureInitializedAsync();
            SyncThemeFromService();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "App initialization failed");
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        UpdateNavigationState();
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        AppInit.ProgressChanged += OnInitProgressChanged;
        Navigation.LocationChanged += OnLocationChanged;
        SyncThemeFromService();
        UpdateNavigationState();
    }

    private void OnInitProgressChanged()
    {
        SyncThemeFromService();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnThemeChanged()
    {
        SyncThemeFromService();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateNavigationState();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SyncThemeFromService() => _isDark = ThemeService.EffectiveTheme == "dark";

    private void UpdateNavigationState()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        _showBottomNav = ShouldShowBottomNav(path);
        _useFixedDockPadding = !_showBottomNav && !path.StartsWith("workout/", StringComparison.Ordinal);
    }

    private static bool ShouldShowBottomNav(string path)
    {
        if (path.StartsWith("workout/", StringComparison.Ordinal)) return false;
        if (path == "plan" || path.StartsWith("plan/", StringComparison.Ordinal)) return false;
        if (path.StartsWith("history/", StringComparison.Ordinal)) return false;
        return true;
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        AppInit.ProgressChanged -= OnInitProgressChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
